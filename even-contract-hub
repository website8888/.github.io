          if (pills[0]) pills[0].textContent = yes0;
          if (pills[1]) pills[1].textContent = no0;
          if (pills[2]) {
            const lean0 = h.pairs[0].odds >= h.pairs[1].odds ? "yes" : "no";
            pills[2].className = "hero-pill " + (lean0 === "yes" ? "yes" : "no");
            pills[2].textContent = `预测方向 · 主流 ${lean0 === "yes" ? "Yes" : "No"}`;
