<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>事件合约市场 · Demo</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #06060b;
      --surface: #14141c;
      --surface2: #1e1e2a;
      --border: #2a2a3a;
      --text: #f4f4f8;
      --muted: #8a8a9a;
      --green: #34d399;
      --green-dim: rgba(52, 211, 153, 0.14);
      --red: #f87171;
      --red-dim: rgba(248, 113, 113, 0.12);
      --accent: #60a5fa;
      --heat: #fbbf24;
      --gold: #fde68a;
      --radius: 12px;
      --font: "DM Sans", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      --title-card: 16px;
      --title-module: clamp(19px, 2.25vw, 24px);
      --title-hero: clamp(24px, 3.15vw, 34px);
      --weight-title: 800;
      --weight-card: 700;
      /* 事件类型 / 热门专题：分类标题统一量级 */
      --hub-category-heading: clamp(19px, 2.05vw, 21px);
    }
    .hub-category-heading {
      font-size: var(--hub-category-heading);
      font-weight: 800;
      letter-spacing: -0.02em;
      line-height: 1.28;
      margin: 0 0 12px;
      color: var(--text);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      line-height: 1.5;
      min-height: 100vh;
      position: relative;
      overflow-x: hidden;
    }
    body::before {
      content: "";
      position: fixed;
      inset: -20%;
      background:
        radial-gradient(ellipse 50% 40% at 18% 8%, rgba(37, 99, 235, 0.2), transparent 55%),
        radial-gradient(ellipse 45% 35% at 88% 15%, rgba(16, 185, 129, 0.14), transparent 50%),
        radial-gradient(ellipse 40% 45% at 50% 100%, rgba(245, 158, 11, 0.1), transparent 45%);
      animation: ambient-drift 18s ease-in-out infinite alternate;
      pointer-events: none;
      z-index: 0;
    }
    @keyframes ambient-drift {
      0% { transform: translate(0, 0) scale(1); opacity: 1; }
      100% { transform: translate(2%, -1%) scale(1.04); opacity: 0.94; }
    }
    a { color: var(--accent); text-decoration: none; }
    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 16px 16px 80px;
      position: relative;
      z-index: 1;
    }

    .site-nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 10px 0 22px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      margin-bottom: 20px;
    }
    .site-brand {
      font-size: 18px;
      font-weight: 800;
      letter-spacing: -0.03em;
      color: var(--text);
    }
    .site-brand span { color: #93c5fd; font-weight: 700; }
    .site-nav-links {
      display: flex;
      gap: 20px;
      font-size: 13px;
      font-weight: 700;
    }
    .site-nav-links a {
      color: var(--muted);
      transition: color 0.15s;
    }
    .site-nav-links a:hover { color: var(--text); }
    .site-nav-links .here {
      color: var(--gold);
      pointer-events: none;
    }

    .module-title {
      font-size: var(--title-module);
      font-weight: var(--weight-title);
      line-height: 1.3;
      margin: 0 0 14px;
      color: var(--text);
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 10px;
      letter-spacing: -0.02em;
    }
    .section-kicker {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #93c5fd;
      margin-bottom: 8px;
    }

    /* 首屏大卡：与下方「市场成交动态」等模块同宽、同窗格 */
    .hero-mega {
      position: relative;
      padding: 0;
      margin-bottom: 12px;
      border: none;
      background: none;
      overflow: visible;
    }
    .hero-card-shell {
      position: relative;
      z-index: 1;
      border: 1px solid var(--border);
      border-radius: 16px;
      background: linear-gradient(180deg, #16161f 0%, #12121a 100%);
      padding: 14px 18px 16px;
      overflow: hidden;
    }
    @media (max-width: 640px) {
      .hero-card-shell {
        padding: 12px 14px 14px;
        border-radius: 14px;
      }
    }
    .hero-carousel-wrap {
      position: relative;
      z-index: 1;
    }
    .hero-carousel {
      position: relative;
    }
    /* Kalshi 式：细边框圆钮 + 序号（位于标题行右侧） */
    .hero-inline-nav {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0;
    }
    .hero-inline-nav-btn {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.2);
      background: rgba(10, 10, 16, 0.55);
      color: #e5e7eb;
      font-size: 18px;
      line-height: 1;
      font-weight: 400;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.15s, border-color 0.15s, color 0.15s;
      padding: 0;
    }
    .hero-inline-nav-btn:hover {
      background: rgba(255, 255, 255, 0.08);
      border-color: rgba(255, 255, 255, 0.28);
      color: #fff;
    }
    .hero-inline-nav-btn:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }
    .hero-inline-nav-count {
      font-size: 12px;
      font-weight: 700;
      font-variant-numeric: tabular-nums;
      color: #9ca3af;
      min-width: 3.2em;
      text-align: center;
      user-select: none;
      letter-spacing: 0.02em;
    }
    .hero-carousel-mask {
      overflow: hidden;
      border-radius: 10px;
      margin: 0;
    }
    .hero-carousel-track {
      display: flex;
      transition: transform 0.5s cubic-bezier(0.25, 0.85, 0.2, 1);
    }
    .hero-carousel-track.hero-carousel-track--instant {
      transition: none;
    }
    .hero-slide {
      flex: 0 0 100%;
      min-width: 0;
      padding: 0 2px 2px;
      box-sizing: border-box;
    }
    .hero-slide-main {
      display: block;
      position: relative;
      padding: 4px 2px 8px;
      border-radius: 0;
      background: none;
      border: none;
      box-shadow: none;
      color: inherit;
    }
    .hero-lead {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
      gap: 14px;
      margin-bottom: 10px;
      min-width: 0;
    }
    .hero-lead-main {
      flex: 1 1 auto;
      min-width: 0;
    }
    .hero-lead-stat {
      flex: 0 0 auto;
      min-width: 0;
    }
    .hero-lead-stat .hero-vol {
      flex-direction: column;
      align-items: flex-end;
      gap: 6px;
      padding: 6px 10px;
      text-align: right;
    }
    .hero-lead-stat .hero-vol > div {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 2px;
    }
    @media (max-width: 640px) {
      .hero-lead {
        flex-direction: column;
        align-items: stretch;
      }
      .hero-lead-stat .hero-vol {
        flex-direction: row;
        justify-content: space-between;
        align-items: baseline;
        text-align: left;
      }
      .hero-lead-stat .hero-vol > div {
        align-items: flex-start;
      }
    }
    .hero-card-tag {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.09em;
      text-transform: uppercase;
      color: #fde047;
      margin-bottom: 5px;
    }
    .hero-card-tag .live-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #34d399;
      box-shadow: 0 0 10px #34d399;
      animation: live-pulse 1.2s ease infinite;
    }
    @keyframes live-pulse { 50% { opacity: 0.5; } }
    .hero-title-row {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 6px;
    }
    .hero-title-row .hero-inline-nav {
      flex-shrink: 0;
      margin-top: 3px;
    }
    a.hero-title-link {
      flex: 1 1 auto;
      min-width: 0;
      color: inherit;
      text-decoration: none;
    }
    a.hero-title-link:hover .hero-event-title {
      color: #93c5fd;
    }
    .hero-slide-main .hero-event-title {
      font-size: var(--title-hero);
      font-weight: var(--weight-title);
      letter-spacing: -0.025em;
      margin: 0;
      line-height: 1.22;
      color: var(--text);
    }
    @media (max-width: 640px) {
      .hero-title-row {
        flex-wrap: wrap;
      }
      .hero-title-row .hero-inline-nav {
        margin-top: 0;
        width: 100%;
        justify-content: flex-end;
      }
    }
    .hero-card-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 6px 10px;
      font-size: 13px;
      color: var(--muted);
      font-weight: 600;
      margin-bottom: 0;
    }
    .hero-card-meta strong { color: #86efac; font-weight: 700; }
    /* 主视区：走势看板（大）+ 右侧窄栏逐笔（固定宽高，列表内滚动） */
    .hero-chart-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 10px;
      align-items: start;
      margin-bottom: 10px;
      min-width: 0;
    }
    @media (max-width: 720px) {
      .hero-chart-row {
        grid-template-columns: 1fr;
      }
    }
    .hero-spark-wrap {
      position: relative;
      border-radius: 12px;
      overflow: hidden;
      background: #0c0c12;
      border: 1px solid rgba(255, 255, 255, 0.08);
      margin-bottom: 0;
      min-width: 0;
      min-height: 236px;
      text-decoration: none;
      color: inherit;
    }
    a.hero-spark-wrap {
      display: flex;
      flex-direction: column;
    }
    a.hero-spark-wrap:hover {
      border-color: rgba(147, 197, 253, 0.22);
    }
    .hero-spark-wrap .spark-label {
      position: absolute;
      top: 6px;
      left: 12px;
      font-size: 10px;
      font-weight: 700;
      color: #9ca3af;
      letter-spacing: 0.04em;
      z-index: 1;
      max-width: calc(100% - 120px);
      line-height: 1.35;
    }
    .hero-spark {
      display: block;
      width: 100%;
      height: 236px;
      flex: 1 1 auto;
      min-height: 236px;
      cursor: crosshair;
      touch-action: none;
    }
    .hero-foot-compact {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .hero-vol {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 8px;
      margin-bottom: 0;
      padding: 7px 10px;
      border-radius: 10px;
      background: rgba(0, 0, 0, 0.35);
      border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .hero-vol .lbl { font-size: 12px; color: var(--muted); font-weight: 600; }
    .hero-vol .num {
      font-size: clamp(22px, 2.6vw, 30px);
      font-weight: 900;
      font-variant-numeric: tabular-nums;
      color: var(--green);
      text-shadow: 0 0 28px rgba(52, 211, 153, 0.38);
      line-height: 1.1;
    }
    .hero-vol .num.tick { animation: vol-pop 0.5s ease; }
    @keyframes vol-pop {
      40% { transform: scale(1.04); }
    }
    .hero-vol .dvol {
      font-size: 13px;
      font-weight: 800;
      color: #fbbf24;
    }
    .hero-top-title {
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.1em;
      color: #6b7280;
      margin-bottom: 4px;
    }
    .hero-duel {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .hero-duel.hero-duel--compact {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
    @media (max-width: 640px) {
      .hero-duel.hero-duel--compact {
        grid-template-columns: 1fr;
      }
    }
    .hero-outcome {
      padding: 6px 8px;
      border-radius: 10px;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }
    .hero-duel--compact .hero-outcome {
      padding: 5px 7px;
    }
    .hero-outcome-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 6px;
      margin-bottom: 4px;
    }
    .hero-outcome-name {
      font-size: 11px;
      font-weight: 800;
      letter-spacing: -0.02em;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .hero-outcome-pct {
      font-size: 13px;
      font-weight: 900;
      font-variant-numeric: tabular-nums;
      color: var(--green);
      flex-shrink: 0;
    }
    .hero-duel--compact .hero-meter {
      margin-bottom: 4px;
    }
    .hero-meter {
      height: 4px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.06);
      overflow: hidden;
      margin-bottom: 5px;
    }
    .hero-meter > i {
      display: block;
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, #3b82f6, #34d399);
      transition: width 0.35s ease;
    }
    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 4px;
    }
    .hero-duel--compact .hero-pill:last-child {
      display: flex;
      flex: 1 1 100%;
      margin-top: 2px;
      font-size: 9px;
      padding: 3px 6px;
      text-align: center;
      justify-content: center;
    }
    .hero-pill {
      display: inline-flex;
      align-items: center;
      font-size: 9px;
      font-weight: 800;
      padding: 3px 6px;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(0, 0, 0, 0.25);
      color: #c4c4d8;
    }
    .hero-pill.yes {
      border-color: rgba(52, 211, 153, 0.45);
      color: var(--green);
      background: var(--green-dim);
    }
    .hero-pill.no {
      border-color: rgba(248, 113, 113, 0.4);
      color: var(--red);
      background: var(--red-dim);
    }
    .hero-cta {
      display: inline-block;
      margin-top: 8px;
      font-size: 11px;
      font-weight: 800;
      color: #93c5fd;
      text-decoration: none;
    }
    .hero-cta:hover {
      text-decoration: underline;
    }

    .hero-dots {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-top: 10px;
      position: relative;
      z-index: 2;
    }
    .hero-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      border: none;
      padding: 0;
      cursor: pointer;
      background: rgba(255, 255, 255, 0.2);
      transition: transform 0.15s, background 0.15s;
    }
    .hero-dot[aria-current="true"] {
      background: var(--gold);
      transform: scale(1.25);
      box-shadow: 0 0 14px rgba(251, 191, 36, 0.5);
    }

    /* 逐笔成交：右栏固定宽度；总高与看板一致，列表区限高滚动 */
    .hero-bubbles-strip {
      display: flex;
      flex-direction: column;
      border-radius: 10px;
      background: rgba(12, 12, 18, 0.65);
      border: 1px solid rgba(255, 255, 255, 0.08);
      overflow: hidden;
      margin-bottom: 0;
      box-sizing: border-box;
      min-width: 0;
    }
    .hero-chart-row .hero-bubbles-strip {
      width: clamp(152px, 19vw, 196px);
      max-width: 196px;
      height: 236px;
      max-height: 236px;
      flex-shrink: 0;
      align-self: start;
    }
    .hero-bubbles-strip h4 {
      padding: 6px 8px;
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #6b7280;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      flex-shrink: 0;
    }
    .hero-bubbles-strip .hero-bubbles-list {
      flex: 1 1 0;
      min-height: 0;
      max-height: 188px;
      overflow-x: hidden;
      overflow-y: auto;
      overscroll-behavior: contain;
      padding: 5px 6px 6px;
      position: relative;
      scroll-behavior: auto;
      scrollbar-width: thin;
      scrollbar-color: rgba(90, 90, 120, 0.55) transparent;
      mask-image: linear-gradient(180deg, transparent 0%, #000 10%, #000 90%, transparent 100%);
      -webkit-mask-image: linear-gradient(180deg, transparent 0%, #000 10%, #000 90%, transparent 100%);
    }
    @media (max-width: 720px) {
      .hero-chart-row .hero-bubbles-strip {
        width: 100%;
        max-width: none;
        height: auto;
        max-height: none;
      }
      .hero-bubbles-strip .hero-bubbles-list {
        max-height: 152px;
      }
    }
    .hero-bubbles-list {
      overflow-x: hidden;
      overflow-y: auto;
      overscroll-behavior: contain;
      padding: 8px 10px 10px;
      position: relative;
      scroll-behavior: auto;
      scrollbar-width: thin;
      scrollbar-color: rgba(90, 90, 120, 0.55) transparent;
      mask-image: linear-gradient(180deg, transparent 0%, #000 8%, #000 92%, transparent 100%);
      -webkit-mask-image: linear-gradient(180deg, transparent 0%, #000 8%, #000 92%, transparent 100%);
    }
    .hero-bubbles-list::-webkit-scrollbar {
      width: 5px;
    }
    .hero-bubbles-list::-webkit-scrollbar-thumb {
      background: rgba(90, 90, 120, 0.55);
      border-radius: 3px;
    }
    .hero-bubble {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      padding: 7px 9px;
      margin-bottom: 4px;
      border-radius: 10px;
      font-size: 11px;
      flex-shrink: 0;
      animation: hero-bubble-in 0.28s ease-out;
    }
    .hero-bubbles-strip .hero-bubble {
      padding: 5px 6px;
      gap: 5px;
      font-size: 10px;
      margin-bottom: 3px;
      border-radius: 8px;
    }
    @keyframes hero-bubble-in {
      from { opacity: 0; transform: translateY(14px) scale(0.98); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }
    .hero-bubble.buy-yes {
      background: var(--green-dim);
      border-left: 3px solid var(--green);
    }
    .hero-bubble.buy-no {
      background: var(--red-dim);
      border-left: 3px solid var(--red);
    }
    .hero-bubble span:first-child {
      color: #e5e7eb;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .hero-bubble-amt {
      font-weight: 900;
      font-variant-numeric: tabular-nums;
      color: var(--gold);
      flex-shrink: 0;
      text-shadow: 0 0 12px rgba(251, 191, 36, 0.3);
    }

    /* 市场成交动态（与 index 对齐） */
    .mid-section { margin-top: 10px; }
    .hot-trades-section {
      position: relative;
      background: linear-gradient(180deg, #16161f 0%, #12121a 100%);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: visible;
      box-shadow:
        0 0 0 1px rgba(245, 158, 11, 0.06),
        0 18px 56px rgba(0, 0, 0, 0.45);
    }
    .hot-trades-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      padding: 16px 18px;
      border-bottom: 1px solid var(--border);
      background: linear-gradient(90deg, rgba(239, 68, 68, 0.12), rgba(37, 99, 235, 0.14), rgba(245, 158, 11, 0.1));
      border-radius: 16px 16px 0 0;
    }
    .hot-trades-title {
      font-size: var(--title-module);
      font-weight: var(--weight-title);
      margin: 0;
      display: flex;
      align-items: center;
      gap: 10px;
      line-height: 1.25;
      color: var(--text);
      letter-spacing: -0.02em;
    }
    .hot-trades-title .pulse-dot {
      width: 9px;
      height: 9px;
      background: #f59e0b;
      border-radius: 50%;
      animation: pulse-dot 1.2s ease-in-out infinite;
      box-shadow: 0 0 14px #f59e0b;
      flex-shrink: 0;
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.65; transform: scale(1.15); }
    }
    .hot-trades-live {
      font-size: 12px;
      color: #fbbf24;
      font-weight: 700;
      letter-spacing: 0.04em;
    }
    .hot-toast-layer {
      position: absolute;
      right: 14px;
      top: 56px;
      width: min(280px, 42vw);
      pointer-events: none;
      z-index: 5;
    }
    .hot-toast {
      background: linear-gradient(90deg, rgba(16, 185, 129, 0.38), rgba(37, 99, 235, 0.22));
      border: 1px solid rgba(52, 211, 153, 0.45);
      border-radius: 10px;
      padding: 10px 12px;
      margin-bottom: 8px;
