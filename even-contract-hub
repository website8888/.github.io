    </section>

    <p class="footer-legal">
      演示站免责声明：期货与衍生品交易存在显著风险，并不适合所有投资者。事件合约由持牌主体在合规框架内提供；文中合约名称仅能视为描述性引用，并不代表与被引用方的赞助或背书关系。
    </p>
  </div>

  <script>
    const DETAIL_HREF = "index.html";

    const HUB_HERO = [
      {
        href: DETAIL_HREF,
        tag: "体育 · MLB",
        title: "2026 MLB 世界大赛冠军",
        schedule: "滚动交易 · 多队并列",
        colors: ["#a78bfa", "#60a5fa"],
        volume: 8018857,
        pairs: [
          { name: "纽约大都会", odds: 0.38 },
          { name: "洛杉矶道奇", odds: 0.29 },
        ],
      },
      {
        href: DETAIL_HREF,
        tag: "政治 · 参议院",
        title: "德州共和党参议员提名",
        schedule: "2026 周期 · 高关注",
        colors: ["#f472b6", "#fbbf24"],
        volume: 3417468,
        pairs: [
          { name: "候选人 Ken P.", odds: 0.6 },
          { name: "挑战者组合", odds: 0.34 },
        ],
      },
      {
        href: DETAIL_HREF,
        tag: "Crypto · BTC",
        title: "Bitcoin 何时触及 $150k",
        schedule: "多日期合约并存",
        colors: ["#22d3ee", "#34d399"],
        volume: 11587083,
        pairs: [
          { name: "2026 上半年内", odds: 0.25 },
          { name: "2026 下半年", odds: 0.42 },
        ],
      },
    ];

    const SPARK_LEN = 72;
    const heroSparkState = [];

    function fmtMoney(n) {
      return (
        "$" +
        n.toLocaleString("en-US", { maximumFractionDigits: 0 })
      );
    }

    function buildSparkHistory(start0, start1) {
      const a0 = [];
      const a1 = [];
      let v0 = start0;
      let v1 = start1;
      for (let i = SPARK_LEN - 1; i >= 0; i--) {
        a0.unshift(Math.max(0.03, Math.min(0.97, v0)));
        a1.unshift(Math.max(0.03, Math.min(0.97, v1)));
        let d0 = (Math.random() - 0.5) * 0.05;
        if (Math.random() < 0.11) d0 += Math.sign(Math.random() - 0.5) * (0.08 + Math.random() * 0.09);
        const d1 = -d0 * 0.82 + (Math.random() - 0.5) * 0.038;
        v0 = Math.max(0.03, Math.min(0.97, v0 + d0));
        v1 = Math.max(0.03, Math.min(0.97, v1 + d1));
      }
      return [a0, a1];
    }

    let heroSlideIdx = 0;
    let heroPhysicalIdx = 1;

    function heroLogicalFromPhysical(p) {
      const n = HUB_HERO.length;
      if (p === 0) return n - 1;
      if (p === n + 1) return 0;
      return p - 1;
    }

    function applyHeroTrackTransform(instant) {
      const track = document.getElementById("heroTrack");
      if (!track) return;
      track.classList.toggle("hero-carousel-track--instant", !!instant);
      track.style.transform = `translateX(-${heroPhysicalIdx * 100}%)`;
      if (instant) {
        void track.offsetWidth;
        track.classList.remove("hero-carousel-track--instant");
      }
    }

    function syncHeroDots() {
      heroSlideIdx = heroLogicalFromPhysical(heroPhysicalIdx);
      const dots = document.getElementById("heroDots");
      if (dots) {
        dots.querySelectorAll(".hero-dot").forEach((d, j) => {
          d.setAttribute("aria-current", j === heroSlideIdx ? "true" : "false");
        });
      }
      document.querySelectorAll(".hero-inline-nav-count").forEach((el) => {
        el.textContent = `${heroSlideIdx + 1} / ${HUB_HERO.length}`;
      });
    }

    function scrollHeroBubblesToEnd() {
      const track = document.getElementById("heroTrack");
      if (!track || !track.children[heroPhysicalIdx]) return;
      const list = track.children[heroPhysicalIdx].querySelector(".hero-bubbles-list");
      if (list) list.scrollTop = list.scrollHeight - list.clientHeight;
    }

    function goHeroSlideLogical(idx) {
      const n = HUB_HERO.length;
      const i = ((idx % n) + n) % n;
      heroPhysicalIdx = i + 1;
      applyHeroTrackTransform(false);
      syncHeroDots();
      requestAnimationFrame(scrollHeroBubblesToEnd);
    }

    function goHeroPhysicalStep(delta) {
      const n = HUB_HERO.length;
      heroPhysicalIdx += delta;
      if (heroPhysicalIdx < 0) heroPhysicalIdx = 0;
      if (heroPhysicalIdx > n + 1) heroPhysicalIdx = n + 1;
      applyHeroTrackTransform(false);
      syncHeroDots();
      requestAnimationFrame(scrollHeroBubblesToEnd);
    }

    function onHeroTrackTransitionEnd(e) {
      const track = document.getElementById("heroTrack");
      if (!track || e.target !== track || e.propertyName !== "transform") return;
      const n = HUB_HERO.length;
      if (heroPhysicalIdx === n + 1) {
        heroPhysicalIdx = 1;
        applyHeroTrackTransform(true);
        syncHeroDots();
      } else if (heroPhysicalIdx === 0) {
        heroPhysicalIdx = n;
        applyHeroTrackTransform(true);
        syncHeroDots();
      }
    }

    function heroSlideTemplate(h, hi, isClone) {
      if (!isClone) {
        const [s0, s1] = buildSparkHistory(h.pairs[0].odds, h.pairs[1].odds);
        h.pairs[0].odds = s0[s0.length - 1];
        h.pairs[1].odds = s1[s1.length - 1];
        heroSparkState.push({ histories: [s0, s1], volume: h.volume, dvol: 0 });
      }
      const lean0 = h.pairs[0].odds >= h.pairs[1].odds ? "yes" : "no";
      const lean1 = h.pairs[1].odds > h.pairs[0].odds ? "yes" : "no";
      const initDvol = (Math.random() * 600 + 120) | 0;
      const navTotal = HUB_HERO.length;
      return `
<div class="hero-slide" data-hero="${hi}">
  <div class="hero-slide-main" data-hero="${hi}">
    <div class="hero-lead">
      <div class="hero-lead-main">
        <div class="hero-card-tag"><span class="live-dot" aria-hidden="true"></span> ${h.tag}</div>
        <div class="hero-title-row">
          <a class="hero-title-link" href="${h.href}"><h2 class="hero-event-title">${h.title}</h2></a>
          <div class="hero-inline-nav" role="group" aria-label="热门事件切换">
            <button type="button" class="hero-inline-nav-btn" data-hero-dir="-1" aria-label="上一则热门事件">‹</button>
            <span class="hero-inline-nav-count" aria-live="polite">1 / ${navTotal}</span>
            <button type="button" class="hero-inline-nav-btn" data-hero-dir="1" aria-label="下一则热门事件">›</button>
          </div>
        </div>
        <div class="hero-card-meta"><span>${h.schedule}</span> · <strong>实时赔率 · 成交热度演示</strong></div>
      </div>
      <div class="hero-lead-stat">
        <div class="hero-vol">
          <div>
            <div class="lbl">事件总成交量（示意）</div>
            <div class="num" data-vol-display="${hi}">${fmtMoney(h.volume)}</div>
          </div>
          <div>
            <div class="lbl">本秒增量</div>
            <div class="dvol" data-dvol="${hi}">+${initDvol}</div>
          </div>
        </div>
      </div>
    </div>
    <div class="hero-chart-row">
      <a class="hero-spark-wrap" href="${h.href}">
        <span class="spark-label">YES 隐含概率 % · 成交量前二合约</span>
        <canvas class="hero-spark" width="400" height="236" aria-hidden="true"></canvas>
      </a>
      <div class="hero-bubbles-strip">
        <h4>逐笔成交</h4>
        <div class="hero-bubbles-list" aria-live="polite"></div>
      </div>
    </div>
    <div class="hero-foot-compact">
      <div class="hero-top-title">交易量最高的两个合约</div>
      <div class="hero-duel hero-duel--compact">
        <div class="hero-outcome">
          <div class="hero-outcome-head">
            <span class="hero-outcome-name">${h.pairs[0].name}</span>
            <span class="hero-outcome-pct" data-pct="${hi}-0">${(h.pairs[0].odds * 100).toFixed(1)}%</span>
          </div>
          <div class="hero-meter"><i style="width:${h.pairs[0].odds * 100}%"></i></div>
          <div class="hero-actions">
            <span class="hero-pill yes">买 Yes ${(h.pairs[0].odds * 100).toFixed(0)}¢</span>
            <span class="hero-pill no">买 No ${((1 - h.pairs[0].odds) * 100).toFixed(0)}¢</span>
            <span class="hero-pill ${lean0 === "yes" ? "yes" : "no"}">预测方向 · 主流 ${lean0 === "yes" ? "Yes" : "No"}</span>
          </div>
        </div>
        <div class="hero-outcome">
          <div class="hero-outcome-head">
            <span class="hero-outcome-name">${h.pairs[1].name}</span>
            <span class="hero-outcome-pct" data-pct="${hi}-1">${(h.pairs[1].odds * 100).toFixed(1)}%</span>
          </div>
          <div class="hero-meter"><i style="width:${h.pairs[1].odds * 100}%"></i></div>
          <div class="hero-actions">
            <span class="hero-pill yes">买 Yes ${(h.pairs[1].odds * 100).toFixed(0)}¢</span>
            <span class="hero-pill no">买 No ${((1 - h.pairs[1].odds) * 100).toFixed(0)}¢</span>
            <span class="hero-pill ${lean1 === "yes" ? "yes" : "no"}">预测方向 · 主流 ${lean1 === "yes" ? "Yes" : "No"}</span>
          </div>
        </div>
      </div>
      <a class="hero-cta" href="${h.href}">打开事件详情 →</a>
    </div>
  </div>
</div>`;
    }

    function onHeroTrackClick(e) {
      const btn = e.target.closest("[data-hero-dir]");
      if (!btn || !e.currentTarget.contains(btn)) return;
      e.preventDefault();
      e.stopPropagation();
      const d = parseInt(btn.getAttribute("data-hero-dir"), 10);
      if (d === -1) goHeroPhysicalStep(-1);
      else if (d === 1) goHeroPhysicalStep(1);
    }

    function renderHeroCarousel() {
      const track = document.getElementById("heroTrack");
      const dots = document.getElementById("heroDots");
      if (!track || !dots) return;
      heroSparkState.length = 0;
      const n = HUB_HERO.length;
      const reals = HUB_HERO.map((h, hi) => heroSlideTemplate(h, hi, false));
      const head = heroSlideTemplate(HUB_HERO[n - 1], n - 1, true);
      const tail = heroSlideTemplate(HUB_HERO[0], 0, true);
      track.innerHTML = head + reals.join("") + tail;
      track.removeEventListener("transitionend", onHeroTrackTransitionEnd);
      track.addEventListener("transitionend", onHeroTrackTransitionEnd);

      heroPhysicalIdx = 1;
      syncHeroDots();
      track.classList.add("hero-carousel-track--instant");
      track.style.transform = `translateX(-${heroPhysicalIdx * 100}%)`;
      void track.offsetWidth;
      track.classList.remove("hero-carousel-track--instant");

      dots.innerHTML = HUB_HERO.map(
        (_, i) =>
          `<button type="button" class="hero-dot" role="tab" aria-label="热门事件 ${i + 1} / ${HUB_HERO.length}" aria-current="${i === 0 ? "true" : "false"}" data-dot="${i}"></button>`
      ).join("");
      dots.querySelectorAll(".hero-dot").forEach((btn) => {
        btn.addEventListener("click", () => goHeroSlideLogical(parseInt(btn.getAttribute("data-dot"), 10)));
      });
      if (!track.dataset.heroNavDelegated) {
        track.dataset.heroNavDelegated = "1";
        track.addEventListener("click", onHeroTrackClick);
      }
      bindHeroSparkInteractions();
      heroSparkPointer = null;
      redrawAllHeroSparks();
    }

    function pushHeroBubble(slideIdxOpt) {
      const si = slideIdxOpt !== undefined ? slideIdxOpt : heroSlideIdx;
      const lists = document.querySelectorAll(`.hero-slide[data-hero="${si}"] .hero-bubbles-list`);
      if (!lists.length) return;
      const h = HUB_HERO[si];
      const yes = Math.random() > 0.4;
      const pair = h.pairs[(Math.random() * 2) | 0];
      const amt = ((Math.random() * 12000 + 180) / 1000).toFixed(2);
      lists.forEach((list) => {
        const div = document.createElement("div");
        div.className = "hero-bubble " + (yes ? "buy-yes" : "buy-no");
        div.innerHTML =
          "<span>" + pair.name + " · " + (yes ? "Yes" : "No") + "</span><span class=\"hero-bubble-amt\">$" + amt + "k</span>";
        list.appendChild(div);
        while (list.children.length > 46) list.removeChild(list.firstChild);
      });
      document.querySelectorAll(`.hero-slide[data-hero="${si}"] .hero-bubbles-list`).forEach((list) => {
        list.scrollTop = list.scrollHeight - list.clientHeight;
      });
    }

    function tickHeroBubblesAutoScroll() {
      const track = document.getElementById("heroTrack");
      if (!track || !track.children[heroPhysicalIdx]) return;
      const list = track.children[heroPhysicalIdx].querySelector(".hero-bubbles-list");
      if (!list) return;
      if (list.scrollHeight <= list.clientHeight + 2) return;
      list.scrollTop += 7;
      const max = list.scrollHeight - list.clientHeight;
      if (list.scrollTop > max) list.scrollTop = max;
    }

    let heroSparkPointer = null;

    function heroSparkAxisDates(pointCount) {
      const out = [];
      const nTick = 4;
      const now = new Date();
      for (let k = 0; k < nTick; k++) {
        const i = Math.round((k * (pointCount - 1)) / (nTick - 1));
        const d = new Date(now);
        d.setDate(d.getDate() - (pointCount - 1 - i));
        const t = `${d.getMonth() + 1}月${d.getDate()}日`;
        out.push({ i, t });
      }
      return out;
    }

    function canvasRoundRect(ctx, x, y, w, h, r) {
      const rr = Math.min(r, w / 2, h / 2);
      ctx.beginPath();
      ctx.moveTo(x + rr, y);
      ctx.arcTo(x + w, y, x + w, y + h, rr);
      ctx.arcTo(x + w, y + h, x, y + h, rr);
      ctx.arcTo(x, y + h, x, y, rr);
      ctx.arcTo(x, y, x + w, y, rr);
      ctx.closePath();
    }

    function drawHeroSpark(canvas, hi, colors, hoverIdxOpt) {
      if (!canvas) return;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const rect = canvas.getBoundingClientRect();
      const w = rect.width || 400;
      const h = rect.height || 236;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      const ctx = canvas.getContext("2d");
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.clearRect(0, 0, w, h);
      const st = heroSparkState[hi];
      if (!st) return;
      const pad = { l: 12, r: 52, t: 30, b: 28 };
      const cw = Math.max(40, w - pad.l - pad.r);
      const ch = Math.max(40, h - pad.t - pad.b);
      const len = st.histories[0].length;
      const hoverIdx =
        hoverIdxOpt !== undefined && hoverIdxOpt !== null
          ? Math.max(0, Math.min(len - 1, hoverIdxOpt))
          : null;

      const gridPcts = [0, 0.25, 0.5, 0.75, 1];
      ctx.strokeStyle = "rgba(255, 255, 255, 0.06)";
      ctx.lineWidth = 1;
      ctx.setLineDash([3, 4]);
      gridPcts.forEach((pct) => {
        const gy = pad.t + ch - pct * ch;
        ctx.beginPath();
        ctx.moveTo(pad.l, gy);
        ctx.lineTo(pad.l + cw, gy);
        ctx.stroke();
      });
      ctx.setLineDash([]);

      ctx.fillStyle = "#7a7a8c";
      ctx.font = "600 10px DM Sans, system-ui, sans-serif";
      ctx.textAlign = "right";
      ctx.textBaseline = "middle";
      gridPcts.forEach((pct) => {
        const gy = pad.t + ch - pct * ch;
        ctx.fillText(`${Math.round(pct * 100)}%`, w - 6, gy);
      });

      const xTicks = heroSparkAxisDates(len);
      ctx.fillStyle = "#6b7280";
      ctx.font = "600 9px DM Sans, system-ui, sans-serif";
      ctx.textAlign = "center";
      ctx.textBaseline = "top";
      xTicks.forEach(({ i, t }) => {
        const x = pad.l + (cw * i) / (len - 1);
        ctx.fillText(t, x, h - pad.b + 6);
      });

      ctx.strokeStyle = "rgba(255, 255, 255, 0.09)";
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(pad.l, pad.t + ch);
      ctx.lineTo(pad.l + cw, pad.t + ch);
      ctx.stroke();

      const drawSeriesSegment = (arr, li, i0, i1, alpha, lineW) => {
        ctx.beginPath();
        for (let i = i0; i <= i1; i++) {
          const x = pad.l + (cw * i) / (len - 1);
          const yn = Math.max(0, Math.min(1, arr[i]));
          const y = pad.t + ch - yn * ch;
          if (i === i0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.strokeStyle = colors[li];
        ctx.lineWidth = lineW;
        ctx.globalAlpha = alpha;
        ctx.stroke();
        ctx.globalAlpha = 1;
      };

      st.histories.forEach((arr, li) => {
        if (hoverIdx != null && hoverIdx < len - 1) {
          drawSeriesSegment(arr, li, hoverIdx, len - 1, li === 0 ? 0.38 : 0.28, li === 0 ? 2 : 1.65);
          drawSeriesSegment(arr, li, 0, hoverIdx, li === 0 ? 1 : 0.72, li === 0 ? 2.35 : 1.9);
        } else {
          drawSeriesSegment(arr, li, 0, len - 1, li === 0 ? 1 : 0.68, li === 0 ? 2.35 : 1.9);
        }
      });

      if (hoverIdx != null) {
        const hx = pad.l + (cw * hoverIdx) / (len - 1);
        ctx.strokeStyle = "rgba(180, 180, 200, 0.55)";
        ctx.lineWidth = 1;
        ctx.setLineDash([4, 3]);
        ctx.beginPath();
        ctx.moveTo(hx, pad.t);
        ctx.lineTo(hx, pad.t + ch);
        ctx.stroke();
        ctx.setLineDash([]);

        const hub = HUB_HERO[hi];
        const xDate = new Date();
        xDate.setDate(xDate.getDate() - (len - 1 - hoverIdx));
        const timeStr = `${xDate.getMonth() + 1}/${xDate.getDate()} · ${String(xDate.getHours()).padStart(2, "0")}:${String(xDate.getMinutes()).padStart(2, "0")}`;
        ctx.font = "600 10px DM Sans, system-ui, sans-serif";
        ctx.fillStyle = "#a1a1b5";
        ctx.textAlign = "center";
        ctx.textBaseline = "bottom";
        ctx.fillText(timeStr, hx, pad.t - 4);

        const pills = [];
        st.histories.forEach((arr, li) => {
          const v = arr[hoverIdx];
          const prev = hoverIdx > 0 ? arr[hoverIdx - 1] : v;
          const up = v >= prev - 0.0001;
          const cents = Math.round(v * 100);
          const pctStr = (v * 100).toFixed(1) + "%";
          const shortName = (hub.pairs[li].name || "").slice(0, 8);
          pills.push({
            color: colors[li],
            arrow: up ? "↑" : "↓",
            main: shortName + " " + cents + "¢",
            sub: pctStr,
          });
        });

        const pillH = 22;
        const pillGap = 5;
        const padX = 8;
        let maxTw = 0;
        ctx.font = "600 11px DM Sans, system-ui, sans-serif";
        pills.forEach((p) => {
          const t = `${p.arrow} ${p.main}  ${p.sub}`;
          maxTw = Math.max(maxTw, ctx.measureText(t).width);
        });
        const pillW = maxTw + padX * 2;
        let px = hx + 10;
        if (px + pillW > pad.l + cw - 2) px = hx - pillW - 10;
        let py = pad.t + 14;
        pills.forEach((p) => {
          const text = `${p.arrow} ${p.main}  ${p.sub}`;
          canvasRoundRect(ctx, px, py, pillW, pillH, 6);
          ctx.fillStyle = p.color;
          ctx.globalAlpha = 0.92;
          ctx.fill();
          ctx.globalAlpha = 1;
          ctx.strokeStyle = "rgba(255,255,255,0.35)";
          ctx.lineWidth = 1;
          canvasRoundRect(ctx, px, py, pillW, pillH, 6);
          ctx.stroke();
          ctx.fillStyle = "#ffffff";
          ctx.textAlign = "left";
          ctx.textBaseline = "middle";
          ctx.fillText(text, px + padX, py + pillH / 2);
          py += pillH + pillGap;
        });

        st.histories.forEach((arr, li) => {
          const v = arr[hoverIdx];
          const yn = Math.max(0, Math.min(1, v));
          const y = pad.t + ch - yn * ch;
          ctx.fillStyle = colors[li];
          ctx.beginPath();
          ctx.arc(hx, y, li === 0 ? 5 : 4.2, 0, Math.PI * 2);
          ctx.fill();
          ctx.strokeStyle = "rgba(0,0,0,0.35)";
          ctx.lineWidth = 1;
          ctx.stroke();
        });
      }
    }

    function redrawAllHeroSparks() {
      HUB_HERO.forEach((h, hi) => {
        document.querySelectorAll(`.hero-slide[data-hero="${hi}"] .hero-spark`).forEach((canv) => {
          const hv =
            heroSparkPointer && heroSparkPointer.canvas === canv ? heroSparkPointer.idx : null;
          drawHeroSpark(canv, hi, h.colors, hv);
        });
      });
    }

    function bindHeroSparkInteractions() {
      const track = document.getElementById("heroTrack");
      if (!track || track.dataset.sparkBound) return;
      track.dataset.sparkBound = "1";
      track.addEventListener("mousemove", (e) => {
        const canvas = e.target.closest(".hero-spark");
        if (!canvas || !track.contains(canvas)) return;
        const slide = canvas.closest(".hero-slide");
        if (!slide) return;
        const hi = parseInt(slide.getAttribute("data-hero"), 10);
        if (!Number.isFinite(hi) || !HUB_HERO[hi]) return;
        const h = HUB_HERO[hi];
        const rect = canvas.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const w = rect.width || 400;
        const padL = 12;
        const padR = 52;
        const cw = Math.max(40, w - padL - padR);
        const len = heroSparkState[hi] ? heroSparkState[hi].histories[0].length : SPARK_LEN;
        let idx = Math.round(((x - padL) / cw) * (len - 1));
        idx = Math.max(0, Math.min(len - 1, idx));
        heroSparkPointer = { canvas, idx, hi };
        redrawAllHeroSparks();
      });
      track.addEventListener("mouseleave", (e) => {
        if (e.relatedTarget && track.contains(e.relatedTarget)) return;
        heroSparkPointer = null;
        redrawAllHeroSparks();
      });
      track.addEventListener("click", (e) => {
        if (e.target.classList && e.target.classList.contains("hero-spark")) {
          e.preventDefault();
          e.stopPropagation();
        }
      });
    }

    function tickHero() {
      HUB_HERO.forEach((h, hi) => {
        const st = heroSparkState[hi];
        if (!st) return;
        const arr0 = st.histories[0];
        const arr1 = st.histories[1];
        const last0 = arr0[arr0.length - 1];
        const last1 = arr1[arr1.length - 1];
        let d0 = (Math.random() - 0.5) * 0.048;
        if (Math.random() < 0.09) d0 += Math.sign(Math.random() - 0.5) * (0.055 + Math.random() * 0.06);
        const d1 = -d0 * 0.78 + (Math.random() - 0.5) * 0.034;
        const n0 = Math.max(0.03, Math.min(0.97, last0 + d0));
        const n1 = Math.max(0.03, Math.min(0.97, last1 + d1));
        arr0.push(n0);
        arr0.shift();
        arr1.push(n1);
        arr1.shift();
        h.pairs[0].odds = arr0[arr0.length - 1];
        h.pairs[1].odds = arr1[arr1.length - 1];
        const bump = (Math.random() * 900 + 150) | 0;
        st.volume += bump;
        st.dvol = bump;
        document.querySelectorAll(`.hero-slide-main[data-hero="${hi}"]`).forEach((card) => {
          const nv = card.querySelector(`[data-vol-display="${hi}"]`);
          if (nv) {
            nv.textContent = fmtMoney(st.volume);
            nv.classList.remove("tick");
            void nv.offsetWidth;
            nv.classList.add("tick");
          }
          const dv = card.querySelector(`[data-dvol="${hi}"]`);
          if (dv) dv.textContent = "+" + String(bump);

          const p0 = card.querySelector(`[data-pct="${hi}-0"]`);
          const p1 = card.querySelector(`[data-pct="${hi}-1"]`);
          if (p0) p0.textContent = (h.pairs[0].odds * 100).toFixed(1) + "%";
          if (p1) p1.textContent = (h.pairs[1].odds * 100).toFixed(1) + "%";
          const meters = card.querySelectorAll(".hero-meter > i");
          if (meters[0]) meters[0].style.width = h.pairs[0].odds * 100 + "%";
          if (meters[1]) meters[1].style.width = h.pairs[1].odds * 100 + "%";

          const pills = card.querySelectorAll(".hero-actions .hero-pill");
          const yes0 = `买 Yes ${(h.pairs[0].odds * 100).toFixed(0)}¢`;
          const no0 = `买 No ${((1 - h.pairs[0].odds) * 100).toFixed(0)}¢`;
