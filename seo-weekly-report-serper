        async function readFileAsCSV(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();

                reader.onload = (e) => {
                    try {
                        if (file.name.endsWith('.csv')) {
                            resolve({ keywordCsv: e.target.result, pageCsv: '' });
                            return;
                        }
                        const data = new Uint8Array(e.target.result);
                        const workbook = XLSX.read(data, { type: 'array' });
                        const names = workbook.SheetNames;
                        const firstSheet = workbook.Sheets[names[0]];
                        const keywordCsv = XLSX.utils.sheet_to_csv(firstSheet);
                        let pageCsv = '';
                        if (names.length > 1) {
                            pageCsv = XLSX.utils.sheet_to_csv(workbook.Sheets[names[1]]);
                        }
                        resolve({ keywordCsv, pageCsv });
                    } catch (err) {
                        reject(err);
                    }
                };

                reader.onerror = () => reject(new Error('文件读取失败'));

                if (file.name.endsWith('.csv')) {
                    reader.readAsText(file);
                } else {
                    reader.readAsArrayBuffer(file);
                }
            });
        }

        function buildSummaryFromGscScreenshot(g) {
            if (!g || !g.prev || !g.curr) return null;
            const p = g.prev;
            const c = g.curr;
            const hasImp = p.impressions && c.impressions;
            const hasClk = p.clicks && c.clicks;
            const hasCtr = p.ctr && c.ctr;
            if (!hasImp && !hasClk && !hasCtr) return null;

            let period = '最近一周 vs 上一周期';
            if (p.dateRange && c.dateRange) {
                period = `${p.dateRange} → ${c.dateRange}`;
            } else if (p.dateRange || c.dateRange) {
                period = [p.dateRange, c.dateRange].filter(Boolean).join(' → ');
            }

            return {
                period,
                total_imp: hasImp ? formatTrendDisplay(c.impressions, p.impressions) : null,
                total_clk: hasClk ? formatTrendDisplay(c.clicks, p.clicks) : null,
                avg_ctr_curr: hasCtr ? c.ctr : null,
                avg_ctr_prev: hasCtr ? p.ctr : null
            };
        }

        function mergeSummaryStats(csvStats, gscExtract) {
            const fromShot = buildSummaryFromGscScreenshot(gscExtract);
            if (!fromShot) {
                return {
                    ...csvStats,
                    _source: 'csv_aggregate'
                };
            }
            return {
                period: fromShot.period || csvStats.period,
                total_imp: fromShot.total_imp != null ? fromShot.total_imp : csvStats.total_imp,
                total_clk: fromShot.total_clk != null ? fromShot.total_clk : csvStats.total_clk,
                avg_ctr_curr: fromShot.avg_ctr_curr != null ? fromShot.avg_ctr_curr : csvStats.avg_ctr_curr,
                avg_ctr_prev: fromShot.avg_ctr_prev != null ? fromShot.avg_ctr_prev : csvStats.avg_ctr_prev,
                _source: 'gsc_screenshot'
            };
        }

        function parseSheetLinesToRows(lines) {
            const rows = [];
            for (let i = 1; i < lines.length; i++) {
                const values = parseCSVLine(lines[i]);
                if (values.length < 5) continue;

                const query = values[0].trim();
                const clkPrev = parseFloat(values[1].replace(/,/g, '')) || 0;
                const clkCurr = parseFloat(values[2].replace(/,/g, '')) || 0;
                const impPrev = parseFloat(values[3].replace(/,/g, '')) || 0;
                const impCurr = parseFloat(values[4].replace(/,/g, '')) || 0;
                const diff = clkCurr - clkPrev;

                rows.push({
                    query, diff, clkCurr, clkPrev, impCurr, impPrev
                });
            }
            return rows;
        }

        function processData(csvContent, pageCsvContent, gscExtract) {
            const lines = csvContent.trim().split('\n');
            if (lines.length < 2) {
                throw new Error('数据表为空或仅含表头');
            }

            let totalClkCurr = 0, totalClkPrev = 0;
            let totalImpCurr = 0, totalImpPrev = 0;
            const keywordsData = parseSheetLinesToRows(lines);

            keywordsData.forEach((item) => {
                totalClkCurr += item.clkCurr;
                totalClkPrev += item.clkPrev;
                totalImpCurr += item.impCurr;
                totalImpPrev += item.impPrev;
            });

            let pagesData = [];
            if (pageCsvContent && String(pageCsvContent).trim()) {
                const plines = String(pageCsvContent).trim().split('\n');
                if (plines.length >= 2) {
                    pagesData = parseSheetLinesToRows(plines);
                }
            }

            // 分类品牌词和非品牌词
            const brandTerms = ['moomoo', 'futu', 'ムームー', '富途'];
            const brandData = [];
            const nonBrandData = [];

            keywordsData.forEach(item => {
                const isBrand = brandTerms.some(term =>
                    item.query.toLowerCase().includes(term.toLowerCase())
                );

                const sign = item.diff > 0 ? '+' : '';
                const display = `${item.query} | ${sign}${Math.round(item.diff)}`;

                const dataObj = { ...item, display };

                if (isBrand) {
                    brandData.push(dataObj);
                } else {
                    nonBrandData.push(dataObj);
                }
            });

            brandData.sort((a, b) => b.diff - a.diff);
            nonBrandData.sort((a, b) => b.diff - a.diff);

            const formatTrend = (curr, prev) => {
                if (prev === 0) return `${Math.round(curr)} (+∞)`;
                const pct = ((curr - prev) / prev) * 100;
                const sign = pct > 0 ? '+' : '';
                return `${Math.round(curr)} (${sign}${pct.toFixed(1)}%)`;
            };

            const calculateCTR = (clicks, impressions) => {
                if (impressions === 0) return '0.00%';
                return `${((clicks / impressions) * 100).toFixed(2)}%`;
            };

            const csvSummary = {
                period: "最近一周 vs 上一周期",
                total_imp: formatTrend(totalImpCurr, totalImpPrev),
                total_clk: formatTrend(totalClkCurr, totalClkPrev),
                avg_ctr_curr: calculateCTR(totalClkCurr, totalImpCurr),
                avg_ctr_prev: calculateCTR(totalClkPrev, totalImpPrev)
            };

            const summary_stats = mergeSummaryStats(csvSummary, gscExtract);

            const pageRisers = pagesData.filter((x) => x.diff > 0).sort((a, b) => b.diff - a.diff).slice(0, 5);
            const pageFallers = pagesData.filter((x) => x.diff < 0).sort((a, b) => a.diff - b.diff).slice(0, 5);
            const pageDisplay = (item) => {
                const sign = item.diff > 0 ? '+' : '';
                return `${item.query} | 点击 ${sign}${Math.round(item.diff)}（本期 ${Math.round(item.clkCurr)} / 上期 ${Math.round(item.clkPrev)}）`;
            };

            const out = {
                summary_stats,
                non_brand_analysis: {
                    risers: nonBrandData.filter(x => x.diff > 0).slice(0, 10).map(x => x.display),
                    fallers: nonBrandData.filter(x => x.diff < 0).reverse().slice(0, 10).map(x => x.display)
                },
                brand_analysis: {
                    risers: brandData.filter(x => x.diff > 0).slice(0, 5).map(x => x.display),
                    fallers: brandData.filter(x => x.diff < 0).reverse().slice(0, 5).map(x => x.display)
                },
                raw_data: keywordsData,
                page_analysis: pagesData.length ? {
                    risers: pageRisers.map(pageDisplay),
                    fallers: pageFallers.map(pageDisplay),
                    risers_rows: pageRisers,
                    fallers_rows: pageFallers,
                    raw_pages: pagesData
                } : null
            };

            if (gscExtract && (gscExtract.prev || gscExtract.curr)) {
                out.gsc_screenshot = {
                    prev: gscExtract.prev,
                    curr: gscExtract.curr,
                    rawOcr: gscExtract.rawOcr ? String(gscExtract.rawOcr).slice(0, 8000) : ''
                };
            }

            return out;
        }

        function parseCSVLine(line) {
            const result = [];
            let current = '';
            let inQuotes = false;

            for (let i = 0; i < line.length; i++) {
                const char = line[i];

                if (char === '"') {
                    inQuotes = !inQuotes;
                } else if (char === ',' && !inQuotes) {
                    result.push(current);
                    current = '';
                } else {
                    current += char;
                }
            }
            result.push(current);

            return result;
        }

        function organicListToMarkdown(organic) {
            if (!organic || !organic.length) return '*（无 organic 结果，请换 query 或检查返回 JSON）*\n';
            return organic.slice(0, 8).map((o, i) => {
                const title = (o.title || '').replace(/\]/g, '');
                const link = o.link || '#';
                const sn = String(o.snippet || '').replace(/\n/g, ' ');
                return `${i + 1}. [${title}](${link}) — ${sn}`;
            }).join('\n') + '\n';
        }

        /**
         * @param {object} data processedData
         */
        function buildSerperReportSection(data) {
            const s = data.serper;
            if (s && s.noQueries) {
                return `### 🔎 Serper 联网检索\n\n*无非品牌「点击增长」词可检索，未发起请求。*\n\n`;
            }
            if (!s || s.skipped) {
                let note = '';
                if (data.serper_note) note = `\n*说明：${data.serper_note}*\n`;
                return `### 🔎 Serper 联网检索\n\n*本期未执行 Serper 或已跳过。*${note}\n`;
            }
            let out = `### 🔎 Serper 联网检索（事实参考）\n\n`;
            for (const e of s.entries || []) {
                const dirLabel = e.direction === 'rise' ? '上涨' : '下跌';
                out += `#### \`${e.keyword}\`（${dirLabel} · 点击差 ${e.diff > 0 ? '+' : ''}${Math.round(e.diff)}）\n\n`;
                out += `- **检索 query**（单次请求，意图：**洞察该词点击上升背后的热点与原因**）：\`${e.query}\`\n\n`;
                if (!e.ok) {
                    out += `- *请求失败：${e.error}*\n\n`;
                    continue;
                }
                out += `- *请从下列 organic 归纳：可能的热点事件、新闻由头、市场/板块情绪；摘要未提则写「摘要未体现」。*\n\n`;
                out += organicListToMarkdown(e.response && e.response.organic);
                out += '\n';
            }
            if (s.marketEntry) {
                out += `#### 市场热点（泛检索 · 大盘/跨资产语境）\n\n`;
                out += `- **检索 query**：\`${s.marketEntry.query}\`\n\n`;
                if (!s.marketEntry.ok) {
                    out += `- *请求失败：${s.marketEntry.error}*\n\n`;
                } else {
                    out += organicListToMarkdown(s.marketEntry.response && s.marketEntry.response.organic);
                }
            }
            return out;
        }

        /**
         * 与 Cursor 分析包 §2b 同构的三列表：基于 Serper organic 自动填充（第二列为说明性占位，第三列为证据摘要）。
