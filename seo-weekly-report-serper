        /** TSV 多行 → GFM 表格（供 Cursor 表格复制粘贴） */
        function tsvLinesToMarkdownTable(blockLines) {
            const rows = blockLines.map((line) => String(line).split('\t').map((c) => c.trim()));
            const n = Math.max(1, ...rows.map((r) => r.length));
            if (n < 2) return blockLines.join('\n');
            const esc = (cell) => String(cell ?? '').replace(/\|/g, '｜').replace(/\r?\n/g, ' ');
            const padRow = (r) => {
                const x = r.slice();
                while (x.length < n) x.push('');
                return x.slice(0, n);
            };
            let md = '| ' + padRow(rows[0]).map(esc).join(' | ') + ' |\n';
            md += '| ' + Array(n).fill('---').join(' | ') + ' |\n';
            for (let i = 1; i < rows.length; i++) {
                md += '| ' + padRow(rows[i]).map(esc).join(' | ') + ' |\n';
            }
            return md.trimEnd();
        }

        function looksLikeMarkdownPipeTable(s) {
            const t = String(s).trim();
            if (!t) return false;
            if (/\n\|\s*:?-{2,}[^|\n]*\|/.test(t) || /^\s*\|\s*:?-{2,}/m.test(t)) return true;
            const lines = t.split('\n').map((l) => l.trim()).filter(Boolean);
            if (lines.length < 2) return false;
            const pipeLines = lines.filter((l) => /^\|/.test(l));
            return pipeLines.length >= 2 && pipeLines.length >= Math.ceil(lines.length * 0.55);
        }

        /**
         * 将 Cursor/表格里复制的「纯文本或 TSV」尽量转为可渲染的 GFM 表格。
         */
        function normalizePastedHotspot2bMarkdown(text) {
            const s = String(text || '').replace(/\r\n/g, '\n').replace(/\r/g, '\n');
            if (!s.trim()) return '';
            if (looksLikeMarkdownPipeTable(s)) return s.trim();

            const allLines = s.split('\n');
            const out = [];
            let i = 0;
            while (i < allLines.length) {
                const rawLine = allLines[i];
                const line = String(rawLine).replace(/\u00a0/g, ' ');
                if (line.includes('\t')) {
                    const block = [];
                    let j = i;
                    while (j < allLines.length && String(allLines[j]).replace(/\u00a0/g, ' ').includes('\t')) {
                        block.push(allLines[j]);
                        j++;
                    }
                    if (block.length >= 2) {
                        out.push(tsvLinesToMarkdownTable(block));
                        i = j;
                        continue;
                    }
                }
                out.push(rawLine);
                i++;
            }
            let merged = out.join('\n').trim();

            if (!looksLikeMarkdownPipeTable(merged) && !merged.includes('\t')) {
                const trySp = tryMultilineSpaceColumnsToTable(merged);
                if (trySp) merged = trySp;
            }
            if (!looksLikeMarkdownPipeTable(merged) && !merged.includes('\n') && merged.includes('|')) {
                const rec = tryRecoverInlinePipeCells(merged);
                if (rec) merged = rec;
            }
            return merged.trim();
        }

        /** 单行内用 | 分隔、但无换行时，按固定 3 列折成多行表 */
        function tryRecoverInlinePipeCells(s) {
            const t = String(s).trim();
            if (t.includes('\n') || !t.includes('|')) return null;
            const parts = t.split(/\s*\|\s*/).map((x) => x.trim()).filter(Boolean);
            if (parts.length < 6) return null;
            const cols = 3;
            if (parts.length % cols !== 0) return null;
            const rows = [];
            for (let i = 0; i < parts.length; i += cols) {
                rows.push(parts.slice(i, i + cols).join('\t'));
            }
            if (rows.length < 2) return null;
            return tsvLinesToMarkdownTable(rows);
        }

        /** 多行、列之间为两个及以上空格（无 Tab）时的保守转换 */
        function tryMultilineSpaceColumnsToTable(s) {
            const lines = s.split('\n').map((l) => l.trim()).filter(Boolean);
            if (lines.length < 2) return null;
            const split = (line) => line.split(/\s{2,}|\u3000{2,}/).map((x) => x.trim()).filter(Boolean);
            const cols0 = split(lines[0]);
            if (cols0.length < 3) return null;
            const n = cols0.length;
            const rows = [];
            for (const ln of lines) {
                const p = split(ln);
                if (p.length < 2) return null;
                rows.push(p);
            }
            if (rows.length < 2) return null;
            const tabbed = rows.map((r) => {
                const cells = r.slice();
                while (cells.length < n) cells.push('');
                return cells.slice(0, n).join('\t');
            });
            return tsvLinesToMarkdownTable(tabbed);
        }

