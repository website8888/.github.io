            html += '<table class="md-table-hotspot-2b"><thead><tr>';
            html += '<th>关键词（及本期点击差）</th><th>上升背后可能的热点/事件/情绪</th><th>证据（标题或摘要原文要点）</th>';
            html += '</tr></thead><tbody>';
            for (const e of entries) {
                const kwCell = `${e.keyword} (${e.diff > 0 ? '+' : ''}${Math.round(e.diff)})`;
                if (!e.ok) {
                    html += `<tr><td>${escapeHtml(mdEscapeReportCell(kwCell))}</td><td>检索失败</td><td>${escapeHtml(mdEscapeReportCell(e.error || '—'))}</td></tr>`;
                    continue;
