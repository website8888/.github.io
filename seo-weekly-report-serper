    <script>
        let processedData = null;
        let finalReport = '';
        /** @type {string} */
        let cursorBundleText = '';
        let uploadedFile = null;
        /** @type {null | { prev: object, curr: object, rawOcr: string }} */
        let gscScreenshotData = null;
        let screenshotObjectUrl = null;

        const SERPER_DIRECT_URL = 'https://google.serper.dev/search';
        const SERPER_CACHE_STORAGE_KEY = 'seo_weekly_report_serper_cache_v1';

        // —— Serper ——
        function getSerperEndpoint() {
            const u = (document.getElementById('serperProxyUrl').value || '').trim();
            return u || SERPER_DIRECT_URL;
        }

        /**
         * @param {string} apiKey
         * @param {string} q
         * @param {{ gl?: string, hl?: string, num?: number }} opts
         */
        async function serperSearch(apiKey, q, opts) {
            const gl = (document.getElementById('serperGl').value || 'jp').trim() || 'jp';
            const hl = (document.getElementById('serperHl').value || 'ja').trim() || 'ja';
            const num = opts && opts.num != null ? opts.num : 5;
            const body = { q, gl, hl, num };
            const url = getSerperEndpoint();
            const headers = {
                'Content-Type': 'application/json',
                'X-API-KEY': apiKey
            };
            const res = await fetch(url, { method: 'POST', headers, body: JSON.stringify(body) });
            const text = await res.text();
            let json;
            try {
                json = JSON.parse(text);
            } catch {
                json = { _parseError: true, raw: text.slice(0, 4000) };
            }
            if (!res.ok) {
                const err = new Error(json.message || json.error || `Serper HTTP ${res.status}`);
                err.detail = json;
                throw err;
            }
            return json;
        }

        /**
         * 仅取非品牌词中「点击增长 diff」最高的前 maxN 个词（用于 Serper 洞察上升原因）。
         * @returns {{ keyword: string, direction: 'rise', diff: number }[]}
         */
        function pickSerperKeywords(processedData, maxN) {
            const brandTerms = ['moomoo', 'futu', 'ムームー', '富途'];
            const raw = (processedData.raw_data || []).filter((row) => {
                const q = String(row.query || '').toLowerCase();
                return !brandTerms.some((t) => q.includes(t.toLowerCase()));
            });
            const risers = raw.filter((r) => r.diff > 0).sort((a, b) => b.diff - a.diff);
            const seen = new Set();
            const out = [];
            for (let i = 0; i < risers.length && out.length < maxN; i++) {
                const kw = String(risers[i].query || '').trim();
                if (!kw || seen.has(kw)) continue;
                seen.add(kw);
                out.push({ keyword: risers[i].query, direction: 'rise', diff: risers[i].diff });
            }
            return out;
        }

        /**
         * 单次 Serper：面向「GSC 点击上升 → 站外热点原因」洞察。
         * 复合：关键词 + 年份语境 + 新闻/趋势/背景/话题词，避免与「纯竞品 LP」强绑定导致结果发散。
         */
        function buildSerperQuery(keyword) {
            const k = String(keyword).trim();
            const y = new Date().getFullYear();
            const hl = (document.getElementById('serperHl').value || 'ja').trim().toLowerCase();
            if (hl === 'ja' || hl === 'jp') {
                return `${k} ${y} ニュース トレンド 注目 理由 背景 話題 相場 人気`;
            }
            return `${k} ${y} news why trending reason headlines catalyst stock market`;
        }

        /** 与当前表单选项 + Excel 解析结果绑定，用于判断缓存是否仍适用（diff 取整避免浮点导致指纹不一致） */
        function computeSerperCacheKey(processedData) {
            const maxKw = Math.min(30, Math.max(1, parseInt(document.getElementById('serperMaxKw').value, 10) || 10));
            const includeMarket = document.getElementById('serperMarketTrend').checked;
            const picked = pickSerperKeywords(processedData, maxKw);
            return JSON.stringify({
                maxKw,
                includeMarket,
                picked: picked.map((p) => ({
                    keyword: String(p.keyword || ''),
                    diff: Math.round(Number(p.diff))
                }))
            });
        }

        /** 宽松匹配：maxKw、泛检索、Serper 关键词顺序与当前 pick 一致即可（兼容旧缓存或 diff 微小差异） */
        function serperCacheLooseMatch(cached, processedData) {
            if (!cached || !cached.serper || cached.serper.skipped) return false;
            const maxKw = Math.min(30, Math.max(1, parseInt(document.getElementById('serperMaxKw').value, 10) || 10));
            const includeMarket = document.getElementById('serperMarketTrend').checked;
            const picked = pickSerperKeywords(processedData, maxKw);
            const meta = cached.meta || {};
            if (meta.maxKw != null && Number(meta.maxKw) !== maxKw) return false;
            if (!!meta.includeMarket !== !!includeMarket) return false;
            return serperCacheKeywordRowsMatch(cached, picked);
        }

        /**
         * 仅匹配关键词列与 maxKw（不比较泛检索）。
         * 避免：缓存时未勾选泛检索、本次勾选后误判为不可用而重新打 API。
         */
        function serperCacheLooseMatchIgnoreMarket(cached, processedData) {
            if (!cached || !cached.serper || cached.serper.skipped) return false;
            const maxKw = Math.min(30, Math.max(1, parseInt(document.getElementById('serperMaxKw').value, 10) || 10));
            const picked = pickSerperKeywords(processedData, maxKw);
            const meta = cached.meta || {};
            if (meta.maxKw != null && Number(meta.maxKw) !== maxKw) return false;
            return serperCacheKeywordRowsMatch(cached, picked);
        }

        function serperCacheKeywordRowsMatch(cached, picked) {
            const riseEntries = (cached.serper.entries || []).filter((e) => e.direction === 'rise');
            if (riseEntries.length !== picked.length) return false;
            for (let i = 0; i < picked.length; i++) {
                if (String(picked[i].keyword).trim() !== String(riseEntries[i].keyword).trim()) return false;
            }
            return true;
        }

        /** @returns {{ hit: boolean, mode: 'strict'|'loose'|'ignoreMarket'|null }} */
        function serperCacheMatchesCurrent(cached, processedData) {
            if (!cached || !cached.serper || cached.serper.skipped) return { hit: false, mode: null };
            const strict = computeSerperCacheKey(processedData);
            if (cached.cacheKey && cached.cacheKey === strict) return { hit: true, mode: 'strict' };
            if (serperCacheLooseMatch(cached, processedData)) return { hit: true, mode: 'loose' };
            if (serperCacheLooseMatchIgnoreMarket(cached, processedData)) return { hit: true, mode: 'ignoreMarket' };
            return { hit: false, mode: null };
        }

        function loadSerperCache() {
            try {
                const raw = localStorage.getItem(SERPER_CACHE_STORAGE_KEY);
                if (!raw) return null;
                return JSON.parse(raw);
            } catch {
                return null;
            }
        }

        function saveSerperCache(serperResult, processedData) {
            if (!serperResult || serperResult.fromCache) return;
            if (serperResult.skipped) return;
            const maxKw = Math.min(30, Math.max(1, parseInt(document.getElementById('serperMaxKw').value, 10) || 10));
            const includeMarket = document.getElementById('serperMarketTrend').checked;
            const picked = pickSerperKeywords(processedData, maxKw);
            let apiCalls = 0;
            if (picked.length > 0) {
                apiCalls = picked.length + (includeMarket ? 1 : 0);
            }
            const cacheKey = computeSerperCacheKey(processedData);
            const payload = {
                savedAt: Date.now(),
                cacheKey,
                serper: {
                    entries: serperResult.entries,
                    marketEntry: serperResult.marketEntry,
                    skipped: serperResult.skipped,
                    error: serperResult.error,
                    noQueries: serperResult.noQueries
                },
                meta: {
                    maxKw,
                    includeMarket,
                    keywordCount: picked.length,
                    apiCalls
                }
            };
            try {
                localStorage.setItem(SERPER_CACHE_STORAGE_KEY, JSON.stringify(payload));
            } catch (e) {
                console.warn('Serper cache save failed', e);
            }
            refreshSerperCacheUI();
        }

        function clearSerperCache() {
            try {
                localStorage.removeItem(SERPER_CACHE_STORAGE_KEY);
            } catch (e) {}
            refreshSerperCacheUI();
            alert('已清除本地 Serper 缓存。');
        }

        function refreshSerperCacheUI() {
            const el = document.getElementById('serperCacheStatus');
            if (!el) return;
            const raw = localStorage.getItem(SERPER_CACHE_STORAGE_KEY);
            if (!raw) {
                el.textContent = '暂无本地 Serper 缓存（成功完成一次联网检索后会自动保存，便于调试时复用）。';
                return;
            }
            try {
                const c = JSON.parse(raw);
                const d = new Date(c.savedAt);
                const timeStr = d.toLocaleString('zh-CN', { hour12: false });
                const kw = c.meta && c.meta.keywordCount != null ? c.meta.keywordCount : ((c.serper && c.serper.entries) ? c.serper.entries.length : 0);
                const inc = c.meta && c.meta.includeMarket;
                const api = c.meta && c.meta.apiCalls != null ? c.meta.apiCalls : (kw + (inc ? 1 : 0));
                const mk = c.meta && c.meta.maxKw != null ? c.meta.maxKw : '—';
                el.innerHTML = `上次缓存：<strong>${timeStr}</strong> · 当时「最多检索关键词数」<strong>${mk}</strong> · 关键词检索 <strong>${kw}</strong> 次${inc ? ' + 泛检索 <strong>1</strong> 次' : ''} · 合计 Serper 请求约 <strong>${api}</strong> 次`;
            } catch {
                el.textContent = '缓存数据损坏，可点击「清除 Serper 缓存」后重新检索。';
            }
        }

        function syncSerperCacheControls() {
            const skip = document.getElementById('serperSkip');
            const use = document.getElementById('serperUseCache');
            if (!skip || !use) return;
            if (skip.checked) {
                use.checked = false;
                use.disabled = true;
            } else {
                use.disabled = false;
            }
        }

        /**
         * @returns {Promise<{ entries: object[], marketEntry: object|null, skipped: boolean, error: string|null }>}
         */
        async function runSerperPipeline(processedData) {
            const skip = document.getElementById('serperSkip').checked;
            const apiKey = (document.getElementById('serperApiKey').value || '').trim();
            const useCacheEl = document.getElementById('serperUseCache');
            const useCache = useCacheEl && useCacheEl.checked && !skip;

            if (skip) {
                await updateProgress(2, 'completed', 100, '已跳过 Serper（与旧版一致）✓');
                return {
                    entries: [],
                    marketEntry: null,
                    skipped: true,
                    error: null
                };
            }

            if (useCache) {
                const cached = loadSerperCache();
                const match = serperCacheMatchesCurrent(cached, processedData);
                if (match.hit && cached.serper) {
                    const t = new Date(cached.savedAt).toLocaleString('zh-CN', { hour12: false });
                    const kc = cached.meta && cached.meta.keywordCount != null ? cached.meta.keywordCount : 0;
                    const inc = cached.meta && cached.meta.includeMarket;
                    const tag = match.mode === 'loose'
                        ? '（关键词与选项一致 · 宽松匹配）'
                        : match.mode === 'ignoreMarket'
                            ? '（泛检索开关与缓存不一致 · 仍用已缓存关键词结果，不重复请求）'
                            : '';
                    await updateProgress(2, 'completed', 100, `已使用本地缓存${tag}（${t} · ${kc} 个关键词${inc ? ' + 泛检索' : ''}）✓`);
                    return { ...cached.serper, fromCache: true, cacheSavedAt: cached.savedAt };
                }
                if (!apiKey) {
                    await updateProgress(2, 'completed', 100, '已勾选使用缓存，但本地缓存与当前数据不一致，且未填写 API Key，已跳过 Serper ✓');
                    return {
                        entries: [],
                        marketEntry: null,
                        skipped: true,
                        error: '缓存与当前关键词/选项不一致，无法使用本地结果；请填写 Serper API Key 后重新联网检索，或取消勾选「使用缓存」。'
                    };
                }
                await updateProgress(2, 'processing', 8, '缓存不可用或与当前数据不一致，正在联网检索…');
            }

            if (!apiKey) {
                await updateProgress(2, 'completed', 100, '未填写 API Key，已跳过 Serper ✓');
                return {
                    entries: [],
                    marketEntry: null,
                    skipped: true,
                    error: '未填写 Serper API Key，已跳过联网检索'
                };
            }
            const maxKw = Math.min(30, Math.max(1, parseInt(document.getElementById('serperMaxKw').value, 10) || 10));
            const includeMarket = document.getElementById('serperMarketTrend').checked;
            const picked = pickSerperKeywords(processedData, maxKw);
            const entries = [];
            const delay = (ms) => new Promise((r) => setTimeout(r, ms));

            let idx = 0;
            const total = picked.length + (includeMarket ? 1 : 0);
            if (total === 0) {
                await updateProgress(2, 'completed', 100, '无非品牌「点击增长」词可检索 ✓');
                const empty = { entries: [], marketEntry: null, skipped: false, noQueries: true, error: null };
                saveSerperCache(empty, processedData);
                return empty;
            }
            for (const p of picked) {
                idx++;
                const q = buildSerperQuery(p.keyword);
                await updateProgress(2, 'processing', Math.min(99, Math.round((idx / total) * 100)), `Serper ${idx}/${total}：${p.keyword.slice(0, 40)}…`);
                try {
                    const json = await serperSearch(apiKey, q, { num: 7 });
                    entries.push({
                        keyword: p.keyword,
                        direction: p.direction,
                        diff: p.diff,
                        query: q,
                        ok: true,
                        response: json
                    });
                } catch (e) {
                    entries.push({
                        keyword: p.keyword,
                        direction: p.direction,
                        diff: p.diff,
                        query: q,
                        ok: false,
                        error: e.message || String(e),
                        response: e.detail || null
                    });
                }
                await delay(350);
            }

            let marketEntry = null;
            if (includeMarket) {
                idx++;
                const mq = `日本株 米国株 マーケット ${new Date().getFullYear()} ニュース トレンド 注目 イベント 相場`;
                await updateProgress(2, 'processing', 99, `Serper ${idx}/${total}：市场热点泛检索…`);
                try {
                    const json = await serperSearch(apiKey, mq, { num: 8 });
                    marketEntry = { query: mq, ok: true, response: json };
                } catch (e) {
                    marketEntry = { query: mq, ok: false, error: e.message || String(e), response: e.detail || null };
                }
            }

            await updateProgress(2, 'completed', 100, `Serper 完成（${entries.filter((e) => e.ok).length}/${entries.length} 条关键词成功）✓`);
            const serperDone = { entries, marketEntry, skipped: false, error: null };
            saveSerperCache(serperDone, processedData);
            return serperDone;
        }

        function resetProgressUI() {
            for (let s = 1; s <= 3; s++) {
                const progressItem = document.getElementById(`progress${s}`);
                const icon = document.getElementById(`icon${s}`);
                const statusEl = document.getElementById(`status${s}`);
                const desc = document.getElementById(`desc${s}`);
                const bar = document.getElementById(`bar${s}`);
                icon.textContent = '⏳';
                progressItem.classList.remove('processing', 'completed');
                statusEl.className = 'progress-status status-pending';
                statusEl.textContent = '等待中';
                bar.style.width = '0%';
                if (s === 1) desc.textContent = '提取关键词数据，计算涨跌幅，分类品牌词与非品牌词';
                if (s === 2) desc.textContent = '对点击增长 Top 词检索站外热点（Serper）';
                if (s === 3) desc.textContent = '合并检索事实与本地指标，生成中英文报告';
            }
        }

        // —— GSC 截图 OCR ——
        function normalizeOcrText(t) {
            return String(t || '')
                .replace(/\r/g, '\n')
                .replace(/,/g, '.')
                .replace(/[Oo](?=\d)/g, '0');
        }

        function parseCompactNumber(s) {
            if (s == null || s === '') return NaN;
            const str = String(s).trim();
            if (/[万萬]/.test(str)) {
                const n = parseFloat(str.replace(/[,，]/g, '').replace(/[万萬]/g, ''));
                if (!isNaN(n)) return n * 1e4;
            }
            const m = str.match(/^([\d.]+)\s*([KkMm])?/i);
            if (!m) return parseFloat(str.replace(/%/g, '')) || NaN;
            let n = parseFloat(m[1]);
            const u = (m[2] || '').toUpperCase();
            if (u === 'K') n *= 1e3;
            if (u === 'M') n *= 1e6;
            return n;
        }

        /** 从 GSC 日期区间字符串取结束日时间戳，用于判断本周期/上一周期 */
        function dateRangeEndMs(dateRangeStr) {
            if (!dateRangeStr) return 0;
            const s = String(dateRangeStr).trim();
            const parts = s.split(/\s*[-–~～]\s*/);
            const last = parts[parts.length - 1] || s;
            let y; let mo; let d;
            const m4 = last.match(/(\d{4})[\/\-.年](\d{1,2})[\/\-.月](\d{1,2})/);
            if (m4) {
                y = +m4[1]; mo = +m4[2]; d = +m4[3];
            } else {
                const m2 = last.match(/(\d{1,2})[\/\-.](\d{1,2})[\/\-.](\d{2,4})/);
                if (!m2) return 0;
                mo = +m2[1]; d = +m2[2]; y = +m2[3];
                if (y < 100) y += y >= 70 ? 1900 : 2000;
            }
            const t = new Date(y, mo - 1, d).getTime();
            return isNaN(t) ? 0 : t;
        }

        /**
         * 按日期结束远近：较早区间为「上一周期」，较晚为「本周期」（与截图中上下顺序无关）。
         */
        function normalizeGscPeriodOrder(parsed) {
            const a = parsed.prev;
            const b = parsed.curr;
            const endA = dateRangeEndMs(a.dateRange);
            const endB = dateRangeEndMs(b.dateRange);
            if (endA && endB && endA > endB) {
                return { prev: b, curr: a, rawOcr: parsed.rawOcr, parseOk: parsed.parseOk };
            }
            if (endA && endB && endA < endB) {
                return parsed;
            }
            return parsed;
        }

        function extractImpressionsPairFromMiddleColumn(colText) {
            if (!colText || !String(colText).trim()) return [];
            const t = normalizeOcrText(colText);
            const wan = t.match(/\d+\.?\d*\s*[万萬]/g);
            if (wan && wan.length >= 2) {
                return wan.slice(0, 2).map((x) => String(x).replace(/\s+/g, ''));
            }
            let mm = t.match(/\d+\.?\d*\s*[Mm]/g) || [];
            if (mm.length < 2) mm = t.match(/\d+\.?\d*\s*[Kk]/g) || [];
            if (mm.length >= 2) {
                return mm.slice(0, 2).map((s) => {
                    const x = s.replace(/\s+/g, '');
                    if (/m/i.test(x)) return x.replace(/m/i, 'M');
                    return x.replace(/k/i, 'K');
                });
            }
            return [];
        }

        function extractAllGscDateRanges(text) {
            const out = [];
            const t = String(text || '');
            let m;
            const re1 = /\d{4}\/\d{1,2}\/\d{1,2}\s*[-–~～]\s*\d{4}\/\d{1,2}\/\d{1,2}/g;
            while ((m = re1.exec(t)) !== null) out.push(m[0]);
            if (out.length >= 2) return out;
            const re2 = /\d{1,2}\/\d{1,2}\/\d{2}\s*-\s*\d{1,2}\/\d{1,2}\/\d{2}/g;
            while ((m = re2.exec(t)) !== null) out.push(m[0]);
            return out;
        }

        function formatTrendDisplay(currStr, prevStr) {
            const curr = parseCompactNumber(currStr);
            const prev = parseCompactNumber(prevStr);
            const cs = (currStr || '—').trim();
            if (!isFinite(curr) || !isFinite(prev)) return `${cs} (—)`;
            if (prev === 0) return `${cs} (+∞)`;
            const pct = ((curr - prev) / prev) * 100;
            const sign = pct > 0 ? '+' : '';
            return `${cs} (${sign}${pct.toFixed(1)}%)`;
        }

        function normalizeKToken(s) {
            return String(s).replace(/\s+/g, '').replace(/[KkXx]$/i, 'K');
        }

        /**
         * 提取 Total clicks 两期数值。OCR 常见问题：写成 Total click、K 被漏识别、40.8 与 49.1 无后缀。
         */
        function extractGscClicksPair(text, lower) {
            const clickM = lower.match(/total\s+clicks?/);
            const clickStart = clickM ? clickM.index : -1;
            const impM = lower.match(/total\s+impressions/);
            const impStart = impM ? impM.index : -1;
            const ctrM = lower.match(/average\s+ctr/);
            const ctrStart = ctrM ? ctrM.index : -1;

            const tryKInString = (str) => {
                const km = str.match(/\d+\.?\d*\s*[Kk]/g) || [];
                return km.slice(0, 2).map(normalizeKToken);
            };

            // 1) 截取「点击」列：从 Total click(s) 到下一个区块标题（支持 OCR 先印出 Impressions 再 Clicks）
            let segClick = '';
            if (clickStart >= 0) {
                const candidates = [impStart, ctrStart].filter((i) => i > clickStart);
                const end = candidates.length ? Math.min(...candidates) : text.length;
                segClick = text.slice(clickStart, end);
            }

            let pair = tryKInString(segClick);
            if (pair.length >= 2) return pair;

            // 2) Total click 与 Total impressions 之间的区间（无论谁先出现）
            if (clickStart >= 0 && impStart >= 0 && clickStart !== impStart) {
                const a = Math.min(clickStart, impStart);
                const b = Math.max(clickStart, impStart);
                pair = tryKInString(text.slice(a, b));
                if (pair.length >= 2) return pair;
            }

            // 3) 全文中的 K 数字（展示多为 M，点击多为 K，一般不与 3.xxM 混淆）
            pair = tryKInString(text);
            if (pair.length >= 2) return pair;

            // 4) 无 K 后缀：OCR 常识别成「40.8」「49.1」（略去 K）。排除 1.3% 类 CTR 与 3.xx（百万展示的误截断）
            const tryDecimalThousands = (str) => {
                const matches = str.match(/\b(\d{1,3}\.\d+)\b/g) || [];
                const nums = matches
                    .map((x) => parseFloat(x))
                    .filter((n) => {
                        if (n >= 2.4 && n <= 4.2) return false;
                        return n >= 1.5 && n <= 500;
                    });
                if (nums.length < 2) return [];
                return nums.slice(0, 2).map((n) => n.toFixed(1).replace(/\.0$/, '') + 'K');
            };

            if (segClick) {
                pair = tryDecimalThousands(segClick);
                if (pair.length >= 2) return pair;
            }
            if (clickStart >= 0 && impStart >= 0) {
                const a = Math.min(clickStart, impStart);
                const b = Math.max(clickStart, impStart);
                pair = tryDecimalThousands(text.slice(a, b));
                if (pair.length >= 2) return pair;
            }

            // 4b) 行优先 OCR：「Total impressions」之前的正文往往是点击列（含 40.8 / 49.1）
            if (impStart > 0) {
                pair = tryDecimalThousands(text.slice(0, impStart));
                if (pair.length >= 2) return pair;
            }

            // 5) 纯数字 4～6 位（40800、49100）
            const tryIntThousands = (str) => {
                const raw = str.match(/\b([4-9]\d{4}|[1-9]\d{5})\b/g) || [];
                if (raw.length < 2) return [];
                return raw.slice(0, 2).map((n) => {
                    const v = parseInt(n, 10);
                    if (v >= 1000) return (v / 1000).toFixed(1).replace(/\.0$/, '') + 'K';
                    return n + 'K';
                });
            };
            pair = tryIntThousands(segClick || '');
            if (pair.length >= 2) return pair;

            return [];
        }

        /**
         * 从 OCR 文本解析 GSC 三卡片：Total clicks (K)、Total impressions (M/K)、Average CTR (%)
         * 约定：每列自上而下为先旧周期、后新周期（与截图一致）
         */
        function parseGscOcrText(raw, columnTexts) {
            const text = normalizeOcrText(raw);
            const lower = text.toLowerCase();

            const clickM = lower.match(/total\s+clicks?|总点击|点击次数/);
            const clickStart = clickM ? clickM.index : -1;
            const impM = lower.match(/total\s+impressions|总曝光|总展示|展示次数|impressions/);
            const impStart = impM ? impM.index : -1;
            const ctrM = lower.match(/average\s+ctr|平均点击率|点击率/);
            const ctrStart = ctrM ? ctrM.index : -1;

            let clicksPair = [];
            if (columnTexts && columnTexts[0]) {
                clicksPair = extractClicksFromLeftColumnText(columnTexts[0]);
            }
            if (clicksPair.length < 2) {
                clicksPair = extractGscClicksPair(text, lower);
            }

            let impPair = [];
            if (impStart >= 0 && ctrStart > impStart) {
                const seg = text.slice(impStart, ctrStart);
                let mm = seg.match(/\d+\.?\d*\s*[Mm]/g) || [];
                if (mm.length < 2) mm = seg.match(/\d+\.?\d*\s*[Kk]/g) || [];
                impPair = mm.slice(0, 2).map(s => {
                    const t = s.replace(/\s+/g, '');
                    if (/m/i.test(t)) return t.replace(/m/i, 'M');
                    return t.replace(/k/i, 'K');
                });
            }
            if (impPair.length < 2) {
                const all = text.match(/\d+\.?\d*\s*[Mm]/g) || [];
                impPair = all.slice(0, 2).map(s => s.replace(/\s+/g, '').replace(/m/i, 'M'));
            }
            if (impPair.length < 2 && columnTexts && columnTexts[1]) {
                impPair = extractImpressionsPairFromMiddleColumn(columnTexts[1]);
            }

            let ctrPair = [];
            if (ctrStart >= 0) {
                const seg = text.slice(ctrStart);
                const pct = seg.match(/\d+\.?\d*\s*%/g) || [];
                ctrPair = pct.slice(0, 2).map(s => s.trim().replace(/\s+/g, ''));
            }
            if (ctrPair.length < 2) {
                const all = text.match(/\d+\.?\d*\s*%/g) || [];
                ctrPair = all.slice(0, 2).map(s => s.trim().replace(/\s+/g, ''));
            }

            const dates = [];
            const reY = /(\d{4}[\/\-.]\d{1,2}[\/\-.]\d{1,2})\s*[-–~～]\s*(\d{4}[\/\-.]\d{1,2}[\/\-.]\d{1,2})/g;
            let m;
            while ((m = reY.exec(text)) !== null) dates.push(`${m[1]} - ${m[2]}`);
            if (dates.length < 2) {
                const reShort = /\d{1,2}\/\d{1,2}\/\d{2,4}\s*[-–~～]\s*\d{1,2}\/\d{1,2}\/\d{2,4}/g;
                while ((m = reShort.exec(text)) !== null) dates.push(m[0]);
            }

            let prevDateRange = '';
            let currDateRange = '';
            if (dates.length >= 2) {
                prevDateRange = dates[0];
                currDateRange = dates[1];
            } else if (dates.length === 1) {
                prevDateRange = dates[0];
            }

            let prev = {
                impressions: impPair[0] || '',
                clicks: clicksPair[0] || '',
                ctr: ctrPair[0] || '',
                dateRange: prevDateRange
            };
            let curr = {
                impressions: impPair[1] || '',
                clicks: clicksPair[1] || '',
                ctr: ctrPair[1] || '',
                dateRange: currDateRange
            };

            const ok =
                (prev.clicks && curr.clicks) ||
                (prev.impressions && curr.impressions) ||
                (prev.ctr && curr.ctr);

            return normalizeGscPeriodOrder({ prev, curr, rawOcr: raw, parseOk: !!ok });
        }

        function applyGscExtractToUI(parsed) {
            const panel = document.getElementById('gscExtractPanel');
            const { prev, curr } = parsed;
            document.getElementById('gscPrevClk').value = prev.clicks || '';
            document.getElementById('gscPrevImp').value = prev.impressions || '';
            document.getElementById('gscPrevCtr').value = prev.ctr || '';
            document.getElementById('gscCurrClk').value = curr.clicks || '';
            document.getElementById('gscCurrImp').value = curr.impressions || '';
            document.getElementById('gscCurrCtr').value = curr.ctr || '';
            document.getElementById('gscRowPrevLabel').textContent = prev.dateRange ? `上一周期 (${prev.dateRange})` : '上一周期';
            document.getElementById('gscRowCurrLabel').textContent = curr.dateRange ? `本周期 (${curr.dateRange})` : '本周期';
            panel.classList.add('active');
        }

        /** 从可编辑表格读回 GSC（优先于仅 OCR 缓存），用于「开始分析」 */
        function readGscDataFromEditableTable() {
            const panel = document.getElementById('gscExtractPanel');
            if (!panel.classList.contains('active')) return null;
            const prev = {
                clicks: document.getElementById('gscPrevClk').value.trim(),
                impressions: document.getElementById('gscPrevImp').value.trim(),
                ctr: document.getElementById('gscPrevCtr').value.trim(),
                dateRange: (document.getElementById('gscRowPrevLabel').textContent.match(/\(([^)]+)\)/) || [])[1] || ''
            };
            const curr = {
                clicks: document.getElementById('gscCurrClk').value.trim(),
                impressions: document.getElementById('gscCurrImp').value.trim(),
                ctr: document.getElementById('gscCurrCtr').value.trim(),
                dateRange: (document.getElementById('gscRowCurrLabel').textContent.match(/\(([^)]+)\)/) || [])[1] || ''
            };
            const ok = (prev.clicks && curr.clicks) || (prev.impressions && curr.impressions) || (prev.ctr && curr.ctr);
            if (!ok) return null;
            const merged = normalizeGscPeriodOrder({ prev, curr, rawOcr: (gscScreenshotData && gscScreenshotData.rawOcr) || '', parseOk: true });
            return { prev: merged.prev, curr: merged.curr, rawOcr: (gscScreenshotData && gscScreenshotData.rawOcr) || '' };
        }

        function imageToCanvasForOcr(img) {
            const maxW = 2000;
            let w = img.naturalWidth || img.width;
            let h = img.naturalHeight || img.height;
            if (w > maxW) {
                h = Math.round((h * maxW) / w);
                w = maxW;
            }
            const canvas = document.createElement('canvas');
            canvas.width = w;
            canvas.height = h;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0, w, h);
            return canvas;
        }

        /** 裁掉上方约 topCutRatio，保留下方（适合整页截图里 GSC 三卡片在偏下位置） */
        function cropBottomFraction(sourceCanvas, topCutRatio) {
            const w = sourceCanvas.width;
            const h = sourceCanvas.height;
            const top = Math.floor(h * topCutRatio);
            const nh = h - top;
            if (nh < 80) return sourceCanvas;
            const out = document.createElement('canvas');
            out.width = w;
            out.height = nh;
            out.getContext('2d').drawImage(sourceCanvas, 0, top, w, nh, 0, 0, w, nh);
            return out;
        }

        /** 裁出左/中/右三列（与 GSC 三卡片同序：Clicks | Impressions | CTR） */
        function cropColumnCanvas(sourceCanvas, colIndex, cols) {
            const w = sourceCanvas.width;
            const h = sourceCanvas.height;
            const cw = Math.floor(w / cols);
            const x = colIndex * cw;
            const out = document.createElement('canvas');
            out.width = cw;
            out.height = h;
            const ctx = out.getContext('2d');
            ctx.drawImage(sourceCanvas, x, 0, cw, h, 0, 0, cw, h);
            return out;
        }

        /** 窄列放大后再 OCR，减轻小字漏识别 */
        function maybeUpscaleCanvas(canvas, minWidth) {
            if (canvas.width >= minWidth) return canvas;
            const scale = Math.min(3, minWidth / canvas.width);
            const out = document.createElement('canvas');
            out.width = Math.round(canvas.width * scale);
            out.height = Math.round(canvas.height * scale);
            const ctx = out.getContext('2d');
            ctx.imageSmoothingEnabled = true;
            ctx.imageSmoothingQuality = 'high';
            ctx.drawImage(canvas, 0, 0, out.width, out.height);
            return out;
        }

        /**
         * 仅从「左列」OCR 文本提取点击两期（不依赖全文里 Total clicks 出现顺序）
         */
        function extractClicksFromLeftColumnText(colText) {
            if (!colText || !String(colText).trim()) return [];
            const t = normalizeOcrText(colText);
            const tryWan = (s) => {
                const wm = s.match(/\d+\.?\d*\s*[万萬]/g) || [];
                return wm.slice(0, 2).map((x) => String(x).replace(/\s+/g, ''));
            };
            let pair = tryWan(t);
            if (pair.length >= 2) return pair;
            const tryK = (s) => {
                const km = s.match(/\d+\.?\d*\s*[KkXx]/g) || [];
                return km.slice(0, 2).map((x) => normalizeKToken(x));
            };
            pair = tryK(t);
            if (pair.length >= 2) return pair;

            const tryDecimalThousands = (str) => {
                const matches = str.match(/\b(\d{1,3}\.\d+)\b/g) || [];
                const nums = matches
                    .map((x) => parseFloat(x))
                    .filter((n) => {
                        if (n >= 2.4 && n <= 4.2) return false;
                        return n >= 1.5 && n <= 500;
                    });
                if (nums.length < 2) return [];
                return nums.slice(0, 2).map((n) => n.toFixed(1).replace(/\.0$/, '') + 'K');
            };
            pair = tryDecimalThousands(t);
            if (pair.length >= 2) return pair;

            const raw = t.match(/\b([4-9]\d{4}|[1-9]\d{5})\b/g) || [];
            if (raw.length >= 2) {
                return raw.slice(0, 2).map((n) => {
                    const v = parseInt(n, 10);
                    return v >= 1000 ? (v / 1000).toFixed(1).replace(/\.0$/, '') + 'K' : n + 'K';
                });
            }
            return [];
        }

        /**
         * 返回整图 OCR + 三列分别 OCR（解决整图阅读顺序导致漏掉蓝色 Total clicks 列）
         */
        async function runOcrOnImageSource(src) {
            const el = new Image();
            await new Promise((resolve, reject) => {
                el.onload = resolve;
                el.onerror = () => reject(new Error('图片加载失败'));
                el.src = src;
            });
            const canvas = imageToCanvasForOcr(el);
            const statusEl = document.getElementById('ocrStatus');
            statusEl.textContent = '正在识别文字（首次加载可能需要下载模型）…';
            statusEl.classList.remove('error');

            if (typeof Tesseract === 'undefined') {
                throw new Error('OCR 库未加载，请检查网络后刷新页面');
            }

            const worker = await Tesseract.createWorker('eng');
            try {
                const { data: { text: fullText } } = await worker.recognize(canvas);

                await worker.setParameters({
                    tessedit_pageseg_mode: '6'
                });

                const ocrOneCol = async (baseCanvas, c) => {
                    let colCanvas = cropColumnCanvas(baseCanvas, c, 3);
                    colCanvas = maybeUpscaleCanvas(colCanvas, 420);
                    const { data: { text } } = await worker.recognize(colCanvas);
                    return text || '';
                };

                const columns = [];
                for (let c = 0; c < 3; c++) {
                    statusEl.textContent = `正在识别第 ${c + 1}/3 列（对齐 GSC 三卡片）…`;
                    columns.push(await ocrOneCol(canvas, c));
                }

                if (extractClicksFromLeftColumnText(columns[0]).length < 2) {
                    statusEl.textContent = '正在对下方区域单独识别点击列（排除页顶工具栏干扰）…';
                    for (const ratio of [0.22, 0.38, 0.52]) {
                        const sub = cropBottomFraction(canvas, ratio);
                        if (sub === canvas) continue;
                        const alt = await ocrOneCol(sub, 0);
                        if (extractClicksFromLeftColumnText(alt).length >= 2) {
                            columns[0] = alt;
                            break;
                        }
                    }
                }

                return { fullText, columns };
            } finally {
                await worker.terminate();
            }
        }

