            md += `代码块内表格**每行单独换行**，与网页工具生成的附录结构一致，便于用户在 Cursor 中点击代码块右上角**复制**整段 Markdown，无需再次向模型索要源码。\n\n`;
            md += `（完）\n\n`;
            md += buildCursorBundleAppendixMarkdown(data);

            return md;
        }

        function refreshCursorBundle() {
            cursorBundleText = buildCursorBundleMarkdown(processedData);
            const el = document.getElementById('cursorBundleText');
            if (el) el.value = cursorBundleText;
        }

        async function copyCursorBundle() {
            refreshCursorBundle();
            const t = cursorBundleText || buildCursorBundleMarkdown(processedData);
            try {
                await navigator.clipboard.writeText(t);
                alert('已复制全文 Markdown 到剪贴板，可粘贴到 Cursor 对话。');
            } catch (e) {
                const el = document.getElementById('cursorBundleText');
                if (el) {
                    el.select();
                    document.execCommand('copy');
                    alert('已尝试复制；若失败请手动全选文本框再复制。');
                }
            }
        }

        function downloadCursorBundle() {
            refreshCursorBundle();
            const t = cursorBundleText || buildCursorBundleMarkdown(processedData);
            const blob = new Blob([t], { type: 'text/markdown;charset=utf-8' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `cursor_bundle_${new Date().toISOString().split('T')[0]}.md`;
            a.click();
            URL.revokeObjectURL(url);
        }

        /** 将 Markdown 转为 HTML（兼容 marked 不同导出方式） */
        function parseMarkdownToHtml(src) {
            const s = String(src ?? '');
            if (typeof marked !== 'undefined' && typeof marked.setOptions === 'function' && !marked._seoGfmInit) {
                try {
                    marked.setOptions({ gfm: true, breaks: false });
                    marked._seoGfmInit = true;
                } catch (e) {}
            }
            if (typeof marked !== 'undefined' && typeof marked.parse === 'function') {
                return marked.parse(s);
            }
            if (typeof marked !== 'undefined' && typeof marked === 'function') {
                return marked(s);
            }
            return s.replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/\n/g, '<br>');
        }

        /** 为 GFM 表格补充 class，使粘贴的 §2b / 长短期表与「数据洞察」内嵌表视觉一致 */
        function decorateMarkdownTables(html) {
            try {
                const wrap = document.createElement('div');
                wrap.innerHTML = html;
                wrap.querySelectorAll('table').forEach((tbl) => {
                    if (tbl.className && String(tbl.className).trim()) return;
                    const first = tbl.querySelector('thead tr') || tbl.querySelector('tr');
                    if (!first) return;
                    const n = first.querySelectorAll('th, td').length;
                    if (n === 3) tbl.classList.add('md-table-hotspot-2b');
                    if (n === 6) tbl.classList.add('md-table-strategy-ops');
                });
                return wrap.innerHTML;
            } catch (e) {
                return html;
            }
        }

        function renderReportHtml(md) {
            return decorateMarkdownTables(parseMarkdownToHtml(md));
        }

        /** 去掉外层 ``` / ```markdown 围栏 */
        function stripOuterMarkdownCodeFence(text) {
            let s = String(text || '').replace(/\r\n/g, '\n');
            s = s.trim();
            if (!s.startsWith('```')) return s;
            const nl = s.indexOf('\n');
            if (nl === -1) {
                return s.replace(/^```\w*\s*/, '').replace(/```\s*$/g, '').trim();
            }
            s = s.slice(nl + 1);
            const lastFence = s.lastIndexOf('\n```');
            if (lastFence !== -1) {
                s = s.slice(0, lastFence);
            } else {
                s = s.replace(/\n```\s*$/m, '').replace(/```\s*$/g, '');
            }
            return s.trim();
        }

        function countGfmHeaderColumns(line) {
            const parts = String(line).split('|');
            if (parts.length < 2) return 0;
            return Math.max(0, parts.length - 2);
        }

        /** 取块内第一个 GFM 表格（表头 + 分隔行 + 数据行） */
        function extractFirstGfmPipeTable(block) {
            const lines = String(block).split('\n');
            for (let i = 0; i < lines.length - 1; i++) {
                const line = lines[i];
                const t = line.trim();
                if (!/^\|/.test(t)) continue;
                const sep = (lines[i + 1] || '').trim();
                if (!/^\|/.test(sep) || !/\|?\s*:?-{3,}/.test(sep)) continue;
                const cols = countGfmHeaderColumns(line);
                if (cols < 2) continue;
                let end = i + 2;
                while (end < lines.length && /^\s*\|/.test(lines[end])) end++;
                return { cols, text: lines.slice(i, end).join('\n').trim() };
            }
            return null;
        }

        /** 策略区（附录 B + C）起始位置：取所有候选中的最小下标 */
        function findStrategySectionStartIndex(s) {
            const text = String(s || '');
            const candidates = [];

            const pushAll = (re) => {
                let m;
                const r = new RegExp(re.source, re.flags.includes('g') ? re.flags : re.flags + 'g');
                while ((m = r.exec(text)) !== null) {
                    candidates.push(m.index);
                }
            };

            pushAll(/###\s*附录\s*[BbＢ][^\n]*/g);
            pushAll(/##\s*附录\s*[BbＢ][^\n]*/g);
            pushAll(/####\s*附录\s*[BbＢ][^\n]*/g);
            pushAll(/###\s*Appendix\s*B[^\n]*/gi);
            pushAll(/##\s*Appendix\s*B[^\n]*/gi);
            pushAll(/###\s*短期方案[^\n]*/g);
            pushAll(/##\s*短期方案[^\n]*/g);

            let best = candidates.length ? Math.min(...candidates) : -1;

            const bySixCol = findStrategyStartBeforeFirstSixColumnTable(text);
            if (bySixCol >= 0 && (best < 0 || bySixCol < best)) {
                best = bySixCol;
            }

            return best;
        }

        /**
         * 首张「6 列」GFM 表前最近的 ### / ## 标题（附录 B/短期/长期），用于模型省略「附录 B」字面时的兜底。
         */
        function findStrategyStartBeforeFirstSixColumnTable(s) {
            const lines = String(s).split('\n');
            let offset = 0;
            for (let i = 0; i < lines.length - 1; i++) {
                const line = lines[i];
                const t = line.trim();
                const sep = (lines[i + 1] || '').trim();
                if (!/^\|/.test(t) || !/^\|/.test(sep) || !/\|?\s*:?-{3,}/.test(sep)) {
                    offset += line.length + 1;
                    continue;
                }
                if (countGfmHeaderColumns(line) !== 6) {
                    offset += line.length + 1;
                    continue;
                }

                let headingIdx = -1;
                for (let j = i - 1; j >= 0 && j >= i - 20; j--) {
                    const L = lines[j].trim();
                    if (!/^#{1,6}\s+/.test(L)) continue;
                    if (/附录\s*[BbＢ]|Appendix\s*B|短期方案|长期方案|附录\s*[CcＣ]|Appendix\s*C/i.test(L)) {
                        headingIdx = j;
                        break;
                    }
                }
                if (headingIdx < 0) {
                    for (let j = i - 1; j >= 0 && j >= i - 5; j--) {
                        const L = lines[j].trim();
                        if (/^#{1,6}\s+/.test(L)) {
                            headingIdx = j;
                            break;
                        }
                    }
                }
                const targetLine = headingIdx >= 0 ? headingIdx : i;
                let off = 0;
                for (let k = 0; k < targetLine; k++) off += lines[k].length + 1;
                return off;
            }
            return -1;
        }

        /** 若热点段误含「附录 B / 短期 6 列表」，截断到该标题之前 */
        function truncateHotspotBeforeStrategyMarkers(hotspotChunk) {
            let h = String(hotspotChunk || '');
            const cut = findStrategySectionStartIndex(h);
            if (cut >= 0) h = h.slice(0, cut).trim();
            h = h.replace(/\n---\s*$/m, '').trim();
            return h;
        }

        /**
         * 将一次粘贴的「完整附录」拆成：数据洞察用 2b 段、策略建议用 B+C 段。
         * 优先按 ### 附录 B / ### 短期方案 / 首张 6 列表切分；绝不把「附录 A 之后」整段都当作热点。
         */
        function splitAppendixMarkdownToHotspotAndStrategy(rawInput) {
            const s = stripOuterMarkdownCodeFence(rawInput);
            if (!s.trim()) return { hotspot: '', strategy: '' };

            const idxStrat = findStrategySectionStartIndex(s);
            const idxA = s.search(/###\s*附录\s*[AaＡ][^\n]*/i);
            const idx2b = s.search(/^##\s*2b[^\n]*/im);

            let hotspot = '';
            let strategy = '';

            if (idxStrat >= 0) {
                strategy = s.slice(idxStrat).trim();
                const before = s.slice(0, idxStrat);

                if (idxA >= 0 && idxA < idxStrat) {
                    hotspot = before.slice(idxA).trim();
                } else if (idx2b >= 0 && idx2b < idxStrat) {
                    hotspot = before.slice(idx2b).trim();
                } else {
                    const tbl = extractFirstGfmPipeTable(before);
                    if (tbl && tbl.cols === 3) {
                        hotspot = tbl.text;
                    } else {
                        const intro = before.trim();
                        hotspot = intro ? truncateHotspotBeforeStrategyMarkers(intro) : '';
                    }
                }
            } else {
                if (idxA >= 0) {
                    hotspot = truncateHotspotBeforeStrategyMarkers(s.slice(idxA).trim());
                } else if (idx2b >= 0) {
                    hotspot = truncateHotspotBeforeStrategyMarkers(s.slice(idx2b).trim());
                } else {
                    const tbl = extractFirstGfmPipeTable(s);
                    if (tbl) {
                        if (tbl.cols === 3) hotspot = tbl.text;
                        else if (tbl.cols === 6) strategy = s.trim();
                    }
                }
            }

            hotspot = truncateHotspotBeforeStrategyMarkers(hotspot);

            return { hotspot, strategy };
        }

        function getCombinedAppendixDisplayForUi(data) {
            if (!data) return '';
            const saved = String(data.combined_appendix_user_raw || '').trim();
            if (saved) return data.combined_appendix_user_raw;
            const a = String(data.hotspot_2b_user_markdown || '').trim();
            const bc = String(data.cursor_strategy_user_markdown || '').trim();
            if (!a && !bc) return '';
            const parts = [];
            if (a) parts.push(a);
            if (bc) parts.push(bc);
            return parts.join('\n\n---\n\n');
        }

        function applyCombinedAppendixToReport() {
            if (!processedData) {
                alert('请先完成「开始分析」。');
                return;
            }
            const el = document.getElementById('combinedAppendixPaste');
            const rawFull = el ? String(el.value || '') : '';
            const raw = rawFull.trim();

            if (!raw) {
                processedData.combined_appendix_user_raw = '';
                processedData.hotspot_2b_user_markdown = '';
                processedData.cursor_strategy_user_markdown = '';
            } else {
                processedData.combined_appendix_user_raw = rawFull;
                const { hotspot, strategy } = splitAppendixMarkdownToHotspotAndStrategy(rawFull);
                processedData.hotspot_2b_user_markdown = hotspot ? normalizePastedHotspot2bMarkdown(hotspot) : '';
                processedData.cursor_strategy_user_markdown = strategy ? normalizePastedHotspot2bMarkdown(strategy) : '';
            }

            finalReport = generateReport(processedData);
            const markdownOutput = document.getElementById('markdownOutput');
            if (markdownOutput) markdownOutput.innerHTML = renderReportHtml(finalReport);
            const jsonOutput = document.getElementById('jsonOutput');
            if (jsonOutput) jsonOutput.textContent = JSON.stringify(processedData, null, 2);

            if (!raw) {
                alert('已清除附录回填，数据洞察与策略建议恢复为默认。');
            } else {
                alert('已按附录 A / B+C 拆分并应用到「热点与上升原因归纳」与「策略建议」。');
            }
        }

        function displayResults() {
            document.getElementById('resultSection').classList.add('active');
            document.getElementById('processBtn').disabled = false;

            const cap = document.getElementById('combinedAppendixPaste');
            if (cap && processedData) {
                cap.value = getCombinedAppendixDisplayForUi(processedData);
            }

            // 显示 Markdown（兼容 marked 不同版本的导出方式）
            const markdownOutput = document.getElementById('markdownOutput');
            markdownOutput.innerHTML = renderReportHtml(finalReport);

            renderSerperRawPanel();

            // 显示 JSON
            const jsonOutput = document.getElementById('jsonOutput');
            jsonOutput.textContent = JSON.stringify(processedData, null, 2);

            refreshCursorBundle();

            // 滚动到结果
            document.getElementById('resultSection').scrollIntoView({ behavior: 'smooth' });
        }

        function switchTab(tab, btn) {
            document.querySelectorAll('.tab-button').forEach(b => b.classList.remove('active'));
            if (btn) btn.classList.add('active');

            document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.remove('active');
            });

            if (tab === 'report') {
                document.getElementById('reportTab').classList.add('active');
            } else if (tab === 'serper') {
                document.getElementById('serperTab').classList.add('active');
            } else if (tab === 'cursor') {
                document.getElementById('cursorTab').classList.add('active');
                refreshCursorBundle();
            } else {
                document.getElementById('jsonTab').classList.add('active');
            }
        }

