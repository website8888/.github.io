        async function updateProgress(step, status, progress, description) {
            const progressItem = document.getElementById(`progress${step}`);
            const icon = document.getElementById(`icon${step}`);
            const statusEl = document.getElementById(`status${step}`);
            const desc = document.getElementById(`desc${step}`);
            const bar = document.getElementById(`bar${step}`);

            // 更新图标
            if (status === 'processing') {
                icon.innerHTML = '<span class="spinner"></span>';
                progressItem.classList.add('processing');
                progressItem.classList.remove('completed');
            } else if (status === 'completed') {
                icon.textContent = '✅';
                progressItem.classList.add('completed');
                progressItem.classList.remove('processing');
            }

            // 更新状态
            statusEl.className = `progress-status status-${status}`;
            statusEl.textContent = status === 'processing' ? '处理中...' :
                                  status === 'completed' ? '完成' : '等待中';

            // 更新描述
            desc.textContent = description;

            // 更新进度条
            bar.style.width = progress + '%';
        }

        function renderSerperRawPanel() {
            const panel = document.getElementById('serperRawPanel');
            const s = processedData && processedData.serper;
            if (s && s.noQueries) {
                panel.innerHTML = '<p class="muted" style="color:#888;">无非品牌「点击增长」词，未发起 Serper 请求。</p>';
                return;
            }
            if (!s || s.skipped || (!(s.entries || []).length && !s.marketEntry)) {
                panel.innerHTML = '<p class="muted" style="color:#888;">本期未产生 Serper 请求或已跳过。</p>';
                return;
            }
            let html = '';
            (s.entries || []).forEach((e, i) => {
                const title = `${e.keyword || ''} · ${e.direction === 'rise' ? '涨' : '跌'} · ${e.ok ? 'OK' : '失败'}`;
                const payload = e.ok ? e.response : { error: e.error, detail: e.response };
                html += `<details class="serper-detail" ${i === 0 ? 'open' : ''}><summary>${escapeHtml(title)} — <code>${escapeHtml((e.query || '').slice(0, 80))}</code></summary><pre>${escapeHtml(JSON.stringify(payload, null, 2))}</pre></details>`;
            });
            if (s.marketEntry) {
                const title = `市场热点泛检索 · ${s.marketEntry.ok ? 'OK' : '失败'}`;
                const payload = s.marketEntry.ok ? s.marketEntry.response : { error: s.marketEntry.error, detail: s.marketEntry.response };
                html += `<details class="serper-detail"><summary>${escapeHtml(title)}</summary><pre>${escapeHtml(JSON.stringify(payload, null, 2))}</pre></details>`;
            }
            panel.innerHTML = html || '<p class="muted">无条目</p>';
        }

