<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>事件合约详情 · Demo</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #06060b;
      --surface: #14141c;
      --surface2: #1e1e2a;
      --border: #2a2a3a;
      --text: #f4f4f8;
      --muted: #8a8a9a;
      --green: #34d399;
      --green-dim: rgba(52, 211, 153, 0.14);
      --red: #f87171;
      --red-dim: rgba(248, 113, 113, 0.12);
      --accent: #60a5fa;
      --heat: #fbbf24;
      --gold: #fde68a;
      --radius: 12px;
      --font: "DM Sans", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      /* 标题：模块级接近 18–24px，卡片级 ≥16px，便于扫读与层级区分 */
      --title-card: 16px;
      --title-module: clamp(19px, 2.25vw, 24px);
      --weight-title: 800;
      --weight-card: 700;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      line-height: 1.5;
      min-height: 100vh;
      position: relative;
      overflow-x: hidden;
    }
    body::before {
      content: "";
      position: fixed;
      inset: -20%;
      background:
        radial-gradient(ellipse 50% 40% at 18% 8%, rgba(37, 99, 235, 0.2), transparent 55%),
        radial-gradient(ellipse 45% 35% at 88% 15%, rgba(16, 185, 129, 0.14), transparent 50%),
        radial-gradient(ellipse 40% 45% at 50% 100%, rgba(245, 158, 11, 0.1), transparent 45%);
      animation: ambient-drift 18s ease-in-out infinite alternate;
      pointer-events: none;
      z-index: 0;
    }
    @keyframes ambient-drift {
      0% { transform: translate(0, 0) scale(1); opacity: 1; }
      100% { transform: translate(2%, -1%) scale(1.04); opacity: 0.94; }
    }
    a { color: var(--accent); text-decoration: none; }
    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 16px 16px 80px;
      position: relative;
      z-index: 1;
    }

    /* 区块主标题：页内独立模块（与侧栏卡片标题同级） */
    .module-title {
      font-size: var(--title-module);
      font-weight: var(--weight-title);
      line-height: 1.3;
      margin: 0 0 14px;
      color: var(--text);
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 10px;
      letter-spacing: -0.02em;
    }
    .module-title .badge-live { flex-shrink: 0; }
    .module-title-meta {
      font-size: 12px;
      font-weight: 600;
      color: var(--muted);
      letter-spacing: 0.04em;
    }

    /* 顶部跑马灯 */
    .hype-marquee-wrap {
      margin-bottom: 18px;
      border-radius: var(--radius);
      overflow: hidden;
      background: linear-gradient(90deg, rgba(239, 68, 68, 0.12), rgba(37, 99, 235, 0.16), rgba(16, 185, 129, 0.12));
      border: 1px solid rgba(251, 191, 36, 0.28);
      mask-image: linear-gradient(90deg, transparent, #000 4%, #000 96%, transparent);
      -webkit-mask-image: linear-gradient(90deg, transparent, #000 4%, #000 96%, transparent);
    }
    .hype-marquee {
      display: flex;
      width: max-content;
      animation: hype-scroll 24s linear infinite;
      padding: 10px 0;
    }
    .hype-marquee:hover { animation-play-state: paused; }
    @keyframes hype-scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .hype-chunk {
      flex-shrink: 0;
      padding: 0 36px;
      font-size: 13px;
      font-weight: 600;
      color: var(--gold);
      white-space: nowrap;
      text-shadow: 0 0 22px rgba(251, 191, 36, 0.35);
    }
    .hype-chunk em { font-style: normal; color: #86efac; margin: 0 0.35em; }

    .page-head { margin-bottom: 18px; }
    .breadcrumb { font-size: 12px; color: var(--muted); margin-bottom: 8px; }
    .breadcrumb span { color: var(--text); }
    h1 {
      font-size: clamp(26px, 4.2vw, 36px);
      font-weight: 800;
      margin-bottom: 6px;
      line-height: 1.2;
      text-shadow: 0 0 40px rgba(255, 255, 255, 0.06);
      letter-spacing: -0.03em;
    }
    .sub { color: var(--muted); font-size: 14px; margin-bottom: 16px; }

    .buzz-bar {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 14px;
      align-items: center;
      padding: 14px 18px;
      background: rgba(0, 0, 0, 0.38);
      border-radius: var(--radius);
      border: 1px solid var(--border);
    }
    @media (max-width: 720px) { .buzz-bar { grid-template-columns: 1fr; } }
    .heat-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    .heat-label {
      font-size: 12px;
      font-weight: 800;
      color: var(--heat);
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .heat-label .fire { animation: fire-wobble 0.65s ease-in-out infinite alternate; display: inline-block; }
    @keyframes fire-wobble {
      from { transform: rotate(-6deg) scale(1); }
      to { transform: rotate(6deg) scale(1.12); }
    }
    .heat-track {
      flex: 1;
      min-width: 140px;
      height: 10px;
      background: #1a1a24;
      border-radius: 999px;
      overflow: hidden;
      border: 1px solid #333;
    }
    .heat-fill {
      height: 100%;
      width: 94%;
      border-radius: 999px;
      background: linear-gradient(90deg, #f59e0b, #ef4444, #fbbf24);
      background-size: 200% 100%;
      animation: heat-flow 2s linear infinite, heat-pulse 1.8s ease-in-out infinite alternate;
    }
    @keyframes heat-flow {
      0% { background-position: 0% 50%; }
      100% { background-position: 200% 50%; }
    }
    @keyframes heat-pulse {
      0% { width: 88%; filter: brightness(1); }
      100% { width: 98%; filter: brightness(1.12); }
    }
    .crowd-stats { display: flex; flex-wrap: wrap; gap: 10px 16px; font-size: 12px; }
    .crowd-stat {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      background: rgba(37, 99, 235, 0.12);
      border-radius: 8px;
      border: 1px solid rgba(59, 130, 246, 0.28);
    }
    .crowd-stat strong { color: var(--gold); font-variant-numeric: tabular-nums; }
    .dot-live {
      width: 6px; height: 6px;
      background: #22c55e;
      border-radius: 50%;
      box-shadow: 0 0 10px #22c55e;
      animation: live-blink 1s steps(2) infinite;
    }
    @keyframes live-blink { 50% { opacity: 0.35; } }

    .grid-main {
      display: grid;
      grid-template-columns: 1fr min(340px, 100%);
      gap: 22px;
      align-items: start;
    }
    @media (max-width: 1024px) {
      .grid-main { grid-template-columns: 1fr; }
      .sidebar {
        order: -1;
        position: relative;
        top: auto;
        max-height: none;
        overflow-y: visible;
        padding-bottom: 0;
        scrollbar-gutter: auto;
      }
    }

    .card {
      background: linear-gradient(165deg, #1e1e2a 0%, #14141c 45%, #16161f 100%);
      border: 1px solid rgba(90, 90, 120, 0.35);
      border-radius: 16px;
      overflow: hidden;
      box-shadow:
        0 0 0 1px rgba(16, 185, 129, 0.05),
        0 24px 72px rgba(0, 0, 0, 0.5),
        0 0 48px rgba(37, 99, 235, 0.07);
      animation: module-glow 4.5s ease-in-out infinite alternate;
    }
    @keyframes module-glow {
      0% { box-shadow: 0 0 0 1px rgba(16, 185, 129, 0.05), 0 24px 72px rgba(0, 0, 0, 0.5), 0 0 40px rgba(37, 99, 235, 0.06); }
      100% { box-shadow: 0 0 0 1px rgba(245, 158, 11, 0.1), 0 24px 72px rgba(0, 0, 0, 0.5), 0 0 72px rgba(16, 185, 129, 0.1); }
    }
    .card-h {
      padding: 14px 18px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px;
      background: linear-gradient(90deg, rgba(239, 68, 68, 0.06), rgba(37, 99, 235, 0.08), rgba(245, 158, 11, 0.05));
    }
    .card-h-meta {
      font-size: 12px;
      font-weight: 600;
      color: var(--muted);
    }
    .card-h-meta.heat { color: var(--heat); }
    .card-h h2 {
      font-size: var(--title-card);
      font-weight: var(--weight-card);
      margin: 0;
      line-height: 1.35;
      letter-spacing: -0.01em;
    }
    /* 与 .module-title 同级的卡片顶栏标题 */
    .card-h--lg h2 {
      font-size: var(--title-module);
      font-weight: var(--weight-title);
      letter-spacing: -0.02em;
    }
    .badge-live {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      font-weight: 700;
      color: var(--green);
      background: var(--green-dim);
      padding: 4px 10px;
      border-radius: 999px;
      box-shadow: 0 0 16px rgba(52, 211, 153, 0.25);
    }
    .badge-live::before {
      content: "";
      width: 6px; height: 6px;
      background: var(--green);
      border-radius: 50%;
      animation: pulse 1s ease infinite;
    }
    @keyframes pulse { 50% { opacity: 0.45; transform: scale(0.9); } }

    .chart-axis-hint {
      font-size: 12px;
      color: var(--muted);
      font-weight: 600;
      margin: -4px 16px 10px;
      line-height: 1.4;
    }

    .chart-row {
      display: grid;
      grid-template-columns: 1fr 210px;
      min-height: 280px;
    }
    @media (max-width: 768px) { .chart-row { grid-template-columns: 1fr; } }
    #eventChart {
      display: block;
      width: 100%;
      height: 280px;
      cursor: crosshair;
      background: linear-gradient(180deg, #08080e 0%, #12121a 100%);
      box-shadow: inset 0 0 48px rgba(37, 99, 235, 0.06);
    }
    .chart-meta {
      padding: 12px;
      border-left: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 10px;
      font-size: 12px;
      background: rgba(0, 0, 0, 0.2);
    }
    @media (max-width: 768px) {
      .chart-meta { border-left: 0; border-top: 1px solid var(--border); }
    }
    .meta-stat .label { color: var(--muted); }
    .meta-stat .value {
      font-size: 22px;
      font-weight: 800;
      font-variant-numeric: tabular-nums;
      color: var(--green);
      text-shadow: 0 0 20px rgba(52, 211, 153, 0.35);
    }
    .trade-bubbles {
      flex: 1;
      overflow: hidden;
      position: relative;
      min-height: 120px;
      border-radius: 10px;
      background: #12121a;
      border: 1px solid var(--border);
    }
    .trade-bubbles h3 {
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--muted);
      padding: 8px 10px;
    }
    .bubble-list { padding: 0 8px 8px; max-height: 140px; overflow: hidden; }
    .bubble {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 6px 8px;
      margin-bottom: 4px;
      border-radius: 8px;
      font-size: 11px;
      animation: slideIn 0.35s ease;
    }
    @keyframes slideIn {
      from { opacity: 0; transform: translateX(8px); }
      to { opacity: 1; transform: translateX(0); }
    }
    .bubble.buy-yes { background: var(--green-dim); border-left: 3px solid var(--green); }
    .bubble.buy-no { background: var(--red-dim); border-left: 3px solid var(--red); }
    .bubble .amt { font-weight: 700; font-variant-numeric: tabular-nums; color: var(--gold); }

    .contract-list { padding: 0; }
    .contract-row {
      border-bottom: 1px solid var(--border);
      transition: background 0.18s, border-color 0.2s;
      position: relative;
    }
    .contract-row:last-child { border-bottom: 0; }
    .contract-row::before {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: 0;
      opacity: 0;
      background: linear-gradient(90deg, transparent, rgba(251, 191, 36, 0.07), transparent);
      pointer-events: none;
      transition: opacity 0.3s;
    }
    .contract-row:hover::before { opacity: 1; }
    .contract-row:hover {
      background: rgba(255, 255, 255, 0.02);
      border-color: rgba(59, 130, 246, 0.2);
    }
    .contract-row.selected {
      background: rgba(88, 166, 255, 0.1);
      box-shadow: inset 3px 0 0 var(--accent);
    }
    .contract-head {
      display: grid;
      grid-template-columns: 1fr auto auto;
      gap: 12px;
      align-items: center;
      padding: 14px 16px;
      cursor: pointer;
    }
    .contract-name { font-weight: 700; font-size: 15px; }
    .odds {
      font-size: 20px;
      font-weight: 800;
      font-variant-numeric: tabular-nums;
      color: var(--green);
      text-shadow: 0 0 18px rgba(52, 211, 153, 0.25);
    }
    .dir-btns { display: flex; gap: 10px; flex-wrap: wrap; }
    .btn-mini {
      font-size: 13px;
      font-weight: 800;
      padding: 10px 16px;
      min-height: 42px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: rgba(0, 0, 0, 0.25);
      color: var(--text);
      cursor: pointer;
      transition: transform 0.1s, border-color 0.15s, box-shadow 0.2s;
    }
    .btn-mini:hover { transform: scale(1.02); }
    .btn-mini.yes { border-color: rgba(52, 211, 153, 0.55); color: var(--green); box-shadow: 0 0 16px rgba(52, 211, 153, 0.12); }
    .btn-mini.no { border-color: rgba(248, 113, 113, 0.5); color: var(--red); }
    .contract-expand {
      display: none;
      padding: 0 16px 16px;
      border-top: 1px dashed var(--border);
    }
    .contract-row.open .contract-expand { display: block; }
    .expand-tabs { display: flex; gap: 6px; margin: 12px 0 8px; }
    .expand-tabs button {
      flex: 1;
      padding: 9px;
      font-size: 12px;
      font-weight: 700;
      border: 1px solid var(--border);
      background: var(--surface2);
      color: var(--muted);
      border-radius: 8px;
      cursor: pointer;
    }
    .expand-tabs button.active {
      background: rgba(88, 166, 255, 0.18);
      color: var(--accent);
      border-color: var(--accent);
    }
    .mini-chart { width: 100%; height: 140px; display: block; border-radius: 10px; background: #0c0c12; border: 1px solid var(--border); cursor: crosshair; touch-action: none; }
    .orderbook {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      font-size: 11px;
      margin-top: 8px;
    }
    .ob-col h4 { color: var(--muted); margin-bottom: 6px; font-size: 10px; text-transform: uppercase; }
    .ob-row { display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px solid var(--border); font-variant-numeric: tabular-nums; }
    .ob-row.asks { color: var(--red); }
    .ob-row.bids { color: var(--green); }

    /* 侧栏：sticky + 视口内可滚动，避免计算器底部被裁切 */
    .sidebar {
      display: flex;
      flex-direction: column;
      gap: 18px;
      position: sticky;
      top: 12px;
      align-self: start;
      max-height: calc(100dvh - 24px);
      overflow-y: auto;
      overflow-x: hidden;
      padding-bottom: 12px;
      -webkit-overflow-scrolling: touch;
      scrollbar-gutter: stable;
    }
    .sidebar::-webkit-scrollbar { width: 7px; }
    .sidebar::-webkit-scrollbar-thumb {
      background: rgba(90, 90, 120, 0.55);
      border-radius: 4px;
    }
    .calc-card {
      flex-shrink: 0;
      padding: 20px;
      padding-bottom: 22px;
      background: linear-gradient(165deg, #1c1c28 0%, #14141e 100%);
      border: 1px solid rgba(59, 130, 246, 0.32);
      border-radius: 16px;
      box-shadow: 0 16px 48px rgba(0, 0, 0, 0.38);
    }
    .calc-card .module-title { margin-bottom: 10px; }
    .calc-tip { font-size: 11px; color: var(--muted); margin-bottom: 14px; line-height: 1.45; }
    .calc-selected { font-size: 12px; color: var(--muted); margin-bottom: 10px; }
    .calc-selected strong { color: var(--text); }
    label.lbl { display: block; font-size: 11px; font-weight: 600; color: #a1a1b5; margin-bottom: 4px; }
    input.inp {
      width: 100%;
      padding: 11px 12px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: #0f0f16;
      color: var(--text);
      font-size: 14px;
      font-variant-numeric: tabular-nums;
      margin-bottom: 12px;
    }
    .side-toggle { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 12px; }
    .side-toggle button {
      padding: 11px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: rgba(42, 42, 58, 0.45);
      color: #e5e7eb;
      font-weight: 700;
      font-size: 12px;
      cursor: pointer;
      transition: all 0.2s;
    }
    .side-toggle button.active-yes { border-color: rgba(52, 211, 153, 0.6); background: rgba(52, 211, 153, 0.16); color: #6ee7b7; }
    .side-toggle button.active-no { border-color: rgba(248, 113, 113, 0.55); background: rgba(248, 113, 113, 0.12); color: #fca5a5; }
    .calc-out { margin-bottom: 14px; }
    .calc-hero {
      text-align: center;
      padding: 18px 14px 16px;
      border-radius: 14px;
      background:
        radial-gradient(ellipse 80% 120% at 50% 0%, rgba(52, 211, 153, 0.22), transparent 55%),
        linear-gradient(145deg, rgba(16, 185, 129, 0.14), rgba(37, 99, 235, 0.1));
      border: 1px solid rgba(52, 211, 153, 0.45);
      box-shadow:
        0 0 40px rgba(52, 211, 153, 0.12),
        inset 0 1px 0 rgba(255, 255, 255, 0.06);
      margin-bottom: 12px;
      animation: hero-glow 3.5s ease-in-out infinite alternate;
    }
    @keyframes hero-glow {
      0% { box-shadow: 0 0 32px rgba(52, 211, 153, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.06); }
      100% { box-shadow: 0 0 48px rgba(52, 211, 153, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.08); }
    }
    .calc-hero-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.06em;
      color: #a7f3d0;
      text-transform: uppercase;
      margin-bottom: 6px;
    }
    .calc-hero-profit {
      font-size: clamp(28px, 8vw, 36px);
      font-weight: 900;
      font-variant-numeric: tabular-nums;
      line-height: 1.1;
      background: linear-gradient(135deg, #fef08a 0%, #4ade80 40%, #34d399 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      filter: drop-shadow(0 0 20px rgba(52, 211, 153, 0.45));
      margin-bottom: 6px;
    }
    .calc-hero-profit.negative {
      background: linear-gradient(135deg, #fca5a5, #f87171);
      -webkit-background-clip: text;
      background-clip: text;
      filter: drop-shadow(0 0 12px rgba(248, 113, 113, 0.35));
    }
    .calc-hero-sub {
      font-size: 12px;
      font-weight: 600;
      color: #c4b5fd;
      font-variant-numeric: tabular-nums;
    }
    .calc-hero-sub span { color: #fde68a; }
    .calc-rows {
      background: rgba(0, 0, 0, 0.35);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 12px;
      padding: 12px 14px;
      font-size: 12px;
    }
    .calc-rows .row { display: flex; justify-content: space-between; align-items: center; gap: 8px; margin-bottom: 8px; }
    .calc-rows .row:last-child { margin-bottom: 0; }
    .calc-rows .row .k { color: var(--muted); }
    .calc-rows .row .v { font-weight: 700; font-variant-numeric: tabular-nums; color: #e5e7eb; }
    .calc-rows .row-highlight .v { color: #6ee7b7; font-size: 13px; }
    .cta {
      width: 100%;
      padding: 14px;
      border: 0;
      border-radius: 12px;
      background: linear-gradient(135deg, #2563eb, #1d4ed8);
      color: #fff;
      font-weight: 800;
      font-size: 15px;
      cursor: pointer;
      box-shadow: 0 8px 28px rgba(37, 99, 235, 0.42);
      transition: transform 0.15s, box-shadow 0.2s;
    }
    .cta:hover { transform: translateY(-2px); box-shadow: 0 12px 36px rgba(37, 99, 235, 0.5); }
    .calc-social-fixed {
      margin-top: 12px;
      padding: 12px 14px;
      border-radius: 10px;
      background: rgba(0, 0, 0, 0.4);
      border: 1px solid rgba(251, 191, 36, 0.22);
      font-size: 12px;
      line-height: 1.5;
      color: #d1d5db;
      text-align: center;
    }
    .calc-social-fixed .sn-user { color: #93c5fd; font-weight: 700; }
    .calc-social-fixed strong { color: #fde68a; font-weight: 800; }
    .sn-amt {
      font-weight: 900;
      font-variant-numeric: tabular-nums;
      color: #4ade80;
      text-shadow: 0 0 14px rgba(52, 211, 153, 0.4);
    }
    .sn-amt.tick { animation: amt-pop 0.45s ease; }
    @keyframes amt-pop {
      0% { transform: scale(1); }
      40% { transform: scale(1.08); }
      100% { transform: scale(1); }
    }

    /* Webull 式合规 / 卖点 */
    .trust-strip {
      margin-top: 22px;
