          <p class="calc-tip">与选中合约联动：按当前示意价估算若结算正确可收回金额与份额，非实盘报价。</p>
          <p class="calc-selected">已选合约：<strong id="selName">—</strong></p>
          <label class="lbl" for="calcAmount">投入金额（USD）</label>
          <input class="inp" type="number" id="calcAmount" value="100" min="1" step="1" />
          <div class="side-toggle">
            <button type="button" id="btnYes" class="active-yes">买入 Yes</button>
            <button type="button" id="btnNo">买入 No</button>
          </div>
          <div class="calc-out" id="calcOut"></div>
          <button type="button" class="cta" id="ctaTrade">在 App 内交易</button>
          <div class="calc-social-fixed" id="calcSocialLine" aria-live="polite">
            <span class="sn-user" id="snUser">用户***8f</span><span> 在「</span><strong id="snContract">洛杉矶道奇</strong><span>」下注 </span><span class="sn-amt" id="snAmt">$2,340</span>
          </div>
        </div>

        <div class="hot24-card" aria-labelledby="hot24Title">
          <div class="hot24-h">
            <h3 id="hot24Title" class="module-title">24h 市场最热事件 <span class="module-title-meta">· VOL</span></h3>
          </div>
          <div class="hot24-list" id="hot24List"></div>
        </div>
      </aside>
    </div>
  </div>

  <script>
    const CONTRACTS = [
      { id: "lad", name: "洛杉矶道奇", odds: 0.29, vol: 46768, trades: 12847 },
      { id: "sea", name: "西雅图水手", odds: 0.078, vol: 205886, trades: 45210 },
      { id: "nyy", name: "纽约洋基", odds: 0.08, vol: 40038, trades: 9832 },
      { id: "tor", name: "多伦多蓝鸟", odds: 0.07, vol: 37559, trades: 7211 },
      { id: "nym", name: "纽约大都会", odds: 0.061, vol: 259407, trades: 31002 },
    ];
    const COLORS = ["#60a5fa", "#34d399", "#fbbf24", "#a78bfa", "#f472b6"];
    let selectedId = CONTRACTS[0].id;
    let calcSide = "yes";
    let openContractId = null;
    let miniView = "chart";

    const historyLen = 80;
    const TOP_N_EVENT = 4;
    const CHART_PAD = { l: 48, r: 20, t: 24, b: 44 };

    function buildOddsHistory() {
      const rows = CONTRACTS.map((c) => {
        const arr = new Array(historyLen);
        let v = c.odds;
        arr[historyLen - 1] = v;
        for (let i = historyLen - 2; i >= 0; i--) {
          let d = (Math.random() - 0.5) * 0.032;
          if (Math.random() < 0.1) d += Math.sign(Math.random() - 0.5) * (0.04 + Math.random() * 0.06);
          v = Math.max(0.01, Math.min(0.99, v + d));
          arr[i] = v;
        }
        return arr;
      });
      for (let i = 0; i < historyLen; i++) {
        if (i % 3 !== 0) continue;
        const a = (Math.random() * CONTRACTS.length) | 0;
        const b = (a + 1 + ((Math.random() * (CONTRACTS.length - 1)) | 0)) % CONTRACTS.length;
        const pull = (Math.random() - 0.5) * 0.014;
        rows[a][i] = Math.max(0.01, Math.min(0.99, rows[a][i] + pull));
        rows[b][i] = Math.max(0.01, Math.min(0.99, rows[b][i] - pull * 0.85));
      }
      return rows;
    }
    const oddsHistory = buildOddsHistory();

    function getTopVolumeIndices(n) {
      return CONTRACTS.map((c, i) => ({ i, vol: c.vol }))
        .sort((a, b) => b.vol - a.vol)
        .slice(0, n)
        .map((x) => x.i);
    }

    const HOT24_EVENTS = [
      { title: "2026 美总统大选", vol: "$156.2M" },
      { title: "2026 超级碗冠军", vol: "$42.1M" },
      { title: "美联储 2026 降息次数", vol: "$28.4M" },
      { title: "NBA 2026 总冠军", vol: "$31.0M" },
      { title: "BTC 年底价格区间", vol: "$19.2M" },
      { title: "2026 MLB 世界大赛冠军", vol: "$8.02M" },
      { title: "欧冠 2025/26 冠军", vol: "$11.0M" },
    ];

    function fmtMoney(n) {
      return "$" + Math.round(n).toLocaleString("en-US");
    }
    function fmtPct(p) {
      return (p * 100).toFixed(1) + "%";
    }

    function setupHypeMarquee() {
      const el = document.getElementById("hypeMarquee");
      const parts = [
        "🔥 刚成交 <em>$4.2K</em> 道奇 YES",
        "⚡ <em>3 秒前</em> 用户***821 扫货大都会",
        "📈 本分钟第 <em>62</em> 笔",
        "💥 水手合约 <em>量价齐升</em>",
        "👀 看盘人数 <em>飙升中</em>",
        "🎯 大单吃掉盘口 <em>$12K</em>",
      ];
      const line = parts.join("      ·      ");
      el.innerHTML = `<span class="hype-chunk">${line}</span><span class="hype-chunk">${line}</span>`;
      setInterval(() => {
        const extra = ` · <em>实时</em> ${CONTRACTS[(Math.random() * CONTRACTS.length) | 0].name}`;
        const line2 = parts.join("      ·      ") + extra;
        el.innerHTML = `<span class="hype-chunk">${line2}</span><span class="hype-chunk">${line2}</span>`;
      }, 14000);
    }

    function setupCrowdPulse() {
      const lv = document.getElementById("liveViewers");
      const om = document.getElementById("ordersPerMin");
      const th = document.getElementById("threadHot");
      setInterval(() => {
        if (lv) lv.textContent = (2200 + Math.floor(Math.random() * 1800)).toLocaleString();
        if (om) om.textContent = String(48 + Math.floor(Math.random() * 75));
        if (th) th.textContent = (1.0 + Math.random() * 0.45).toFixed(1) + "k";
      }, 1900);
    }

    function renderHot24List() {
      const root = document.getElementById("hot24List");
      if (!root) return;
      root.innerHTML = HOT24_EVENTS.map(
        (e, i) => `
        <div class="hot24-row">
          <span class="hot24-rank">${i + 1}</span>
          <span class="hot24-name">${e.title}</span>
          <span class="hot24-vol">${e.vol}</span>
        </div>`
      ).join("");
    }

    function renderLegend() {
      const el = document.getElementById("chartLegend");
      const topIdx = getTopVolumeIndices(TOP_N_EVENT);
      el.innerHTML = topIdx
        .map(
          (i) =>
            `<span><i style="background:${COLORS[i]};color:${COLORS[i]}"></i>${CONTRACTS[i].name}</span>`
        )
        .join("");
    }

    function syncOddsToDom() {
      CONTRACTS.forEach((c) => {
        const row = document.querySelector(`.contract-row[data-id="${c.id}"]`);
        if (!row) return;
        const oddsEl = row.querySelector(".odds");
        if (oddsEl) oddsEl.textContent = fmtPct(c.odds);
        const yesBtn = row.querySelector(".btn-mini.yes");
        const noBtn = row.querySelector(".btn-mini.no");
        if (yesBtn) yesBtn.textContent = `买 Yes ${(c.odds * 100).toFixed(0)}¢`;
        if (noBtn) noBtn.textContent = `买 No ${((1 - c.odds) * 100).toFixed(0)}¢`;
      });
    }

    function renderContracts() {
      const root = document.getElementById("contractList");
      root.innerHTML = CONTRACTS.map((c) => {
        const open = openContractId === c.id;
        return `
        <div class="contract-row ${selectedId === c.id ? "selected" : ""} ${open ? "open" : ""}" data-id="${c.id}">
          <div class="contract-head">
            <span class="contract-name">${c.name}</span>
            <span class="odds">${fmtPct(c.odds)}</span>
            <div class="dir-btns">
              <button type="button" class="btn-mini yes" data-act="yes">买 Yes ${(c.odds * 100).toFixed(0)}¢</button>
              <button type="button" class="btn-mini no" data-act="no">买 No ${((1 - c.odds) * 100).toFixed(0)}¢</button>
            </div>
          </div>
          <div class="contract-expand">
            <div class="expand-tabs">
              <button type="button" class="${miniView === "chart" && open ? "active" : ""}" data-tab="chart">合约赔率走势</button>
              <button type="button" class="${miniView === "orderbook" && open ? "active" : ""}" data-tab="orderbook">交易摆盘</button>
            </div>
            <canvas class="mini-chart" data-mini="${c.id}" style="display:${miniView === "chart" || !open ? "block" : "none"}"></canvas>
            <div class="orderbook" id="ob-${c.id}" style="display:${miniView === "orderbook" && open ? "grid" : "none"}"></div>
          </div>
        </div>`;
      }).join("");

      root.querySelectorAll(".contract-head").forEach((head) => {
        head.addEventListener("click", (e) => {
          if (e.target.closest(".btn-mini")) return;
          const row = head.closest(".contract-row");
          const id = row.dataset.id;
          selectedId = id;
          openContractId = openContractId === id ? null : id;
          updateCalc();
          tickSnLine();
          renderContracts();
          if (openContractId) requestAnimationFrame(() => drawMiniChart());
        });
      });
      root.querySelectorAll(".btn-mini").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.stopPropagation();
          const row = btn.closest(".contract-row");
          selectedId = row.dataset.id;
          calcSide = btn.dataset.act;
          document.getElementById("btnYes").classList.toggle("active-yes", calcSide === "yes");
          document.getElementById("btnNo").classList.toggle("active-no", calcSide === "no");
          renderContracts();
          updateCalc();
          tickSnLine();
        });
      });
      root.querySelectorAll(".expand-tabs button").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.stopPropagation();
          miniView = btn.dataset.tab;
          const row = btn.closest(".contract-row");
          openContractId = row.dataset.id;
          renderContracts();
          requestAnimationFrame(() => drawMiniChart());
        });
      });
      if (openContractId) {
        renderOrderbook(openContractId);
        drawMiniChart();
      }
    }

    function renderOrderbook(id) {
      const c = CONTRACTS.find((x) => x.id === id);
      if (!c) return;
      const el = document.getElementById("ob-" + id);
      if (!el) return;
      const mid = c.odds;
      const asks = [0.01, 0.02, 0.03].map((x) => ({
        p: (mid + x).toFixed(2),
        sz: (8000 + Math.random() * 4000) | 0,
      }));
      const bids = [0.01, 0.02, 0.03].map((x) => ({
        p: Math.max(0.01, mid - x).toFixed(2),
        sz: (7000 + Math.random() * 5000) | 0,
      }));
      el.innerHTML = `
        <div class="ob-col">
          <h4>卖盘 Asks</h4>
          ${asks.map((r) => `<div class="ob-row asks"><span>${(r.p * 100).toFixed(1)}¢</span><span>${r.sz.toLocaleString()}</span></div>`).join("")}
        </div>
        <div class="ob-col">
          <h4>买盘 Bids</h4>
          ${bids.map((r) => `<div class="ob-row bids"><span>${(r.p * 100).toFixed(1)}¢</span><span>${r.sz.toLocaleString()}</span></div>`).join("")}
        </div>`;
    }

    const eventCanvas = document.getElementById("eventChart");
    const eventCtx = eventCanvas.getContext("2d");

    function resizeCanvas() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const rect = eventCanvas.getBoundingClientRect();
      eventCanvas.width = rect.width * dpr;
      eventCanvas.height = rect.height * dpr;
      eventCtx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function eventChartRoundRect(ctx, x, y, w, h, r) {
      const rr = Math.min(r, w / 2, h / 2);
      ctx.beginPath();
      ctx.moveTo(x + rr, y);
      ctx.arcTo(x + w, y, x + w, y + h, rr);
      ctx.arcTo(x + w, y + h, x, y + h, rr);
      ctx.arcTo(x, y + h, x, y, rr);
      ctx.arcTo(x, y, x + w, y, rr);
      ctx.closePath();
    }

    function drawEventChart(hoverIndex = null) {
      const w = eventCanvas.getBoundingClientRect().width;
      const h = eventCanvas.getBoundingClientRect().height;
      eventCtx.clearRect(0, 0, w, h);
      const pad = CHART_PAD;
      const cw = w - pad.l - pad.r;
      const ch = h - pad.t - pad.b;
      const topIdx = getTopVolumeIndices(TOP_N_EVENT);
      let gmin = Infinity;
      let gmax = -Infinity;
      topIdx.forEach((si) => {
        oddsHistory[si].forEach((v) => {
          const p = v * 100;
          gmin = Math.min(gmin, p);
          gmax = Math.max(gmax, p);
        });
      });
      if (!isFinite(gmin) || !isFinite(gmax)) return;
      let span = gmax - gmin;
      if (span < 2) span = 2;
      gmin = Math.max(0, gmin - span * 0.12);
      gmax = Math.min(100, gmax + span * 0.12);
      const yScale = gmax - gmin || 1;

      eventCtx.strokeStyle = "#2a2a3a";
      eventCtx.lineWidth = 1;
      eventCtx.fillStyle = "#6b7280";
      eventCtx.font = "11px DM Sans, sans-serif";
      eventCtx.textAlign = "right";
      eventCtx.textBaseline = "middle";
      for (let g = 0; g <= 4; g++) {
        const frac = g / 4;
        const val = gmin + yScale * (1 - frac);
        const y = pad.t + (ch * g) / 4;
        eventCtx.beginPath();
        eventCtx.moveTo(pad.l, y);
        eventCtx.lineTo(pad.l + cw, y);
        eventCtx.stroke();
        eventCtx.fillText(`${val.toFixed(1)}%`, pad.l - 8, y);
      }

      const selSi = CONTRACTS.findIndex((x) => x.id === selectedId);
      const hi =
        hoverIndex != null && hoverIndex >= 0 && hoverIndex < historyLen ? hoverIndex : null;

      const strokePart = (si, i0, i1, alpha, lineW, glow) => {
        const arr = oddsHistory[si];
        eventCtx.beginPath();
        for (let i = i0; i <= i1; i++) {
          const pct = arr[i] * 100;
          const x = pad.l + (cw * i) / (arr.length - 1);
          const y = pad.t + ch - ((pct - gmin) / yScale) * ch;
          if (i === i0) eventCtx.moveTo(x, y);
          else eventCtx.lineTo(x, y);
        }
        eventCtx.strokeStyle = COLORS[si];
        eventCtx.lineWidth = lineW;
        eventCtx.globalAlpha = alpha;
        if (glow) {
          eventCtx.shadowColor = COLORS[si];
          eventCtx.shadowBlur = 12;
        } else eventCtx.shadowBlur = 0;
        eventCtx.stroke();
        eventCtx.shadowBlur = 0;
        eventCtx.globalAlpha = 1;
      };

      topIdx.forEach((si) => {
        const sel = selSi === si;
        const lw = sel ? 3 : 1.85;
        if (hi != null && hi < historyLen - 1) {
          strokePart(si, hi, historyLen - 1, sel ? 0.38 : 0.28, lw * 0.92, false);
          strokePart(si, 0, hi, sel ? 1 : 0.58, lw, sel);
        } else {
          strokePart(si, 0, historyLen - 1, sel ? 1 : 0.58, lw, sel);
        }
      });

      if (hi == null) {
        topIdx.forEach((si) => {
          const arr = oddsHistory[si];
          const last = arr[arr.length - 1] * 100;
          const lx = pad.l + cw;
          const ly = pad.t + ch - ((last - gmin) / yScale) * ch;
          eventCtx.fillStyle = COLORS[si];
          eventCtx.beginPath();
          eventCtx.arc(lx, ly, selSi === si ? 5.5 : 3.5, 0, Math.PI * 2);
          eventCtx.fill();
        });
      }

      if (hi != null) {
        const hx = pad.l + (cw * hi) / (historyLen - 1);
        eventCtx.strokeStyle = "rgba(160, 160, 180, 0.55)";
        eventCtx.lineWidth = 1;
        eventCtx.setLineDash([4, 4]);
        eventCtx.beginPath();
        eventCtx.moveTo(hx, pad.t);
        eventCtx.lineTo(hx, pad.t + ch);
        eventCtx.stroke();
        eventCtx.setLineDash([]);

        const secAgo = historyLen - 1 - hi;
        eventCtx.font = "600 11px DM Sans, sans-serif";
        eventCtx.fillStyle = "#9ca3af";
        eventCtx.textAlign = "center";
        eventCtx.textBaseline = "bottom";
        eventCtx.fillText(secAgo === 0 ? "现在" : `约 −${secAgo}s`, hx, pad.t - 2);

        const pills = [];
        topIdx.forEach((si) => {
          const arr = oddsHistory[si];
          const v = arr[hi];
          const prev = hi > 0 ? arr[hi - 1] : v;
          const up = v >= prev - 1e-6;
          const name = CONTRACTS[si].name.slice(0, 6);
          pills.push({
            color: COLORS[si],
            arrow: up ? "↑" : "↓",
            main: name + " · " + Math.round(v * 100) + "¢",
            sub: (v * 100).toFixed(1) + "%",
          });
        });

        eventCtx.font = "600 11px DM Sans, sans-serif";
        const pillH = 24;
        const gap = 5;
        const padX = 9;
        let maxW = 0;
        pills.forEach((p) => {
          maxW = Math.max(maxW, eventCtx.measureText(`${p.arrow} ${p.main}  ${p.sub}`).width);
        });
        const pillW = maxW + padX * 2;
        let px = hx + 10;
        if (px + pillW > pad.l + cw - 4) px = hx - pillW - 10;
        let py = pad.t + 12;
        pills.forEach((p) => {
          const text = `${p.arrow} ${p.main}  ${p.sub}`;
          eventChartRoundRect(eventCtx, px, py, pillW, pillH, 7);
          eventCtx.fillStyle = p.color;
          eventCtx.globalAlpha = 0.94;
          eventCtx.fill();
          eventCtx.globalAlpha = 1;
          eventCtx.strokeStyle = "rgba(255,255,255,0.3)";
          eventCtx.lineWidth = 1;
          eventChartRoundRect(eventCtx, px, py, pillW, pillH, 7);
          eventCtx.stroke();
          eventCtx.fillStyle = "#fff";
          eventCtx.textAlign = "left";
          eventCtx.textBaseline = "middle";
          eventCtx.fillText(text, px + padX, py + pillH / 2);
          py += pillH + gap;
        });

        topIdx.forEach((si) => {
          const arr = oddsHistory[si];
          const pct = arr[hi] * 100;
          const hy = pad.t + ch - ((pct - gmin) / yScale) * ch;
          eventCtx.fillStyle = COLORS[si];
          eventCtx.beginPath();
          eventCtx.arc(hx, hy, selSi === si ? 5.5 : 4.5, 0, Math.PI * 2);
          eventCtx.fill();
          eventCtx.strokeStyle = "rgba(0,0,0,0.4)";
          eventCtx.lineWidth = 1;
          eventCtx.stroke();
          eventCtx.setLineDash([2, 3]);
          eventCtx.strokeStyle = COLORS[si];
          eventCtx.globalAlpha = 0.45;
          eventCtx.beginPath();
          eventCtx.moveTo(pad.l, hy);
          eventCtx.lineTo(hx, hy);
          eventCtx.stroke();
          eventCtx.setLineDash([]);
          eventCtx.globalAlpha = 1;
        });
      }

      eventCtx.fillStyle = "#6b7280";
      eventCtx.font = "11px DM Sans, sans-serif";
      eventCtx.textAlign = "center";
      eventCtx.textBaseline = "top";
      eventCtx.fillText("较早", pad.l, h - 36);
      eventCtx.fillText("约 −40s", pad.l + cw / 2, h - 36);
      eventCtx.fillText("现在", pad.l + cw, h - 36);
      eventCtx.font = "10px DM Sans, sans-serif";
      eventCtx.fillText("时间（约近 " + historyLen + " 秒 · Demo）", pad.l + cw / 2, h - 14);
    }

    let miniChartHover = null;

    function drawMiniChart() {
      if (!openContractId) return;
      const c = CONTRACTS.find((x) => x.id === openContractId);
      if (!c || miniView !== "chart") return;
      const canv = document.querySelector(`canvas[data-mini="${openContractId}"]`);
      if (!canv) return;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const rect = canv.getBoundingClientRect();
      canv.width = rect.width * dpr;
      canv.height = rect.height * dpr;
      const ctx = canv.getContext("2d");
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const w = rect.width;
      const h = rect.height;
      const idx = CONTRACTS.indexOf(c);
      const arr = oddsHistory[idx];
      const mp = { l: 38, r: 6, t: 8, b: 30 };
      const cw = w - mp.l - mp.r;
      const ch = h - mp.t - mp.b;
      ctx.clearRect(0, 0, w, h);
      const pctArr = arr.map((v) => v * 100);
      let gmin = Math.min(...pctArr);
      let gmax = Math.max(...pctArr);
      let span = gmax - gmin || 1;
      if (span < 1.5) span = 1.5;
      gmin = Math.max(0, gmin - span * 0.18);
      gmax = Math.min(100, gmax + span * 0.18);
      const yScale = gmax - gmin || 1;
      const hi =
        miniChartHover != null && miniChartHover >= 0 && miniChartHover < historyLen
          ? miniChartHover
          : null;

      ctx.strokeStyle = "#2a2a3a";
      ctx.lineWidth = 1;
      ctx.fillStyle = "#6b7280";
      ctx.font = "10px DM Sans, sans-serif";
      ctx.textAlign = "right";
      ctx.textBaseline = "middle";
      for (let g = 0; g <= 2; g++) {
        const frac = g / 2;
        const val = gmin + yScale * (1 - frac);
        const y = mp.t + (ch * g) / 2;
        ctx.beginPath();
        ctx.moveTo(mp.l, y);
        ctx.lineTo(mp.l + cw, y);
        ctx.stroke();
        ctx.fillText(`${val.toFixed(0)}%`, mp.l - 4, y);
      }

      const strokeSeg = (i0, i1, alpha, lw, glow) => {
        ctx.beginPath();
        for (let i = i0; i <= i1; i++) {
          const pct = arr[i] * 100;
          const x = mp.l + (cw * i) / (arr.length - 1);
          const y = mp.t + ch - ((pct - gmin) / yScale) * ch;
          if (i === i0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.strokeStyle = COLORS[idx];
        ctx.lineWidth = lw;
        ctx.globalAlpha = alpha;
        if (glow) {
          ctx.shadowColor = COLORS[idx];
          ctx.shadowBlur = 8;
        } else ctx.shadowBlur = 0;
        ctx.stroke();
        ctx.shadowBlur = 0;
        ctx.globalAlpha = 1;
      };

      if (hi != null && hi < historyLen - 1) {
        strokeSeg(hi, historyLen - 1, 0.35, 1.65, false);
        strokeSeg(0, hi, 1, 2.15, true);
      } else {
        strokeSeg(0, historyLen - 1, 1, 2.15, true);
      }

      ctx.fillStyle = COLORS[idx];
      ctx.globalAlpha = 0.12;
      ctx.beginPath();
      arr.forEach((v, i) => {
        const pct = v * 100;
        const x = mp.l + (cw * i) / (arr.length - 1);
        const y = mp.t + ch - ((pct - gmin) / yScale) * ch;
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      });
      ctx.lineTo(mp.l + cw, mp.t + ch);
      ctx.lineTo(mp.l, mp.t + ch);
      ctx.closePath();
      ctx.fill();
      ctx.globalAlpha = 1;

      if (hi != null) {
        const hx = mp.l + (cw * hi) / (arr.length - 1);
        ctx.strokeStyle = "rgba(150, 160, 190, 0.55)";
        ctx.setLineDash([3, 3]);
        ctx.beginPath();
        ctx.moveTo(hx, mp.t);
        ctx.lineTo(hx, mp.t + ch);
        ctx.stroke();
        ctx.setLineDash([]);
        const pct = arr[hi] * 100;
        const hy = mp.t + ch - ((pct - gmin) / yScale) * ch;
        ctx.fillStyle = COLORS[idx];
        ctx.beginPath();
        ctx.arc(hx, hy, 5, 0, Math.PI * 2);
        ctx.fill();
        ctx.strokeStyle = "rgba(0,0,0,0.35)";
        ctx.lineWidth = 1;
        ctx.stroke();
        const prev = hi > 0 ? arr[hi - 1] : arr[hi];
        const up = arr[hi] >= prev - 1e-6;
        const sec = historyLen - 1 - hi;
        ctx.font = "600 10px DM Sans, sans-serif";
        ctx.fillStyle = "#c4c4d8";
        ctx.textAlign = "center";
        ctx.textBaseline = "top";
        ctx.fillText(
          `${up ? "↑" : "↓"} Yes ${(arr[hi] * 100).toFixed(1)}% · ${sec === 0 ? "现在" : "−" + sec + "s"}`,
          mp.l + cw / 2,
          h - 22
        );
      }

      ctx.textAlign = "center";
      ctx.textBaseline = "top";
      ctx.fillStyle = "#6b7280";
      ctx.font = "10px DM Sans, sans-serif";
      ctx.fillText("时间 →", mp.l + cw / 2, h - 36);
      ctx.fillText("悬停查看各时点（Demo）", mp.l + cw / 2, h - 8);
    }

    function setupMiniChartHover() {
      const root = document.getElementById("contractList");
      if (!root || root.dataset.miniHoverBound) return;
      root.dataset.miniHoverBound = "1";
      root.addEventListener("mousemove", (e) => {
        const canv = e.target.closest("canvas.mini-chart");
        if (!canv || miniView !== "chart" || openContractId !== canv.getAttribute("data-mini")) {
          if (miniChartHover !== null) {
            miniChartHover = null;
            drawMiniChart();
          }
          return;
        }
        const rect = canv.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const mpL = 38;
        const mpR = 6;
        const cw = Math.max(8, rect.width - mpL - mpR);
        let ix = Math.round(((x - mpL) / cw) * (historyLen - 1));
        ix = Math.max(0, Math.min(historyLen - 1, ix));
        if (miniChartHover !== ix) {
          miniChartHover = ix;
          drawMiniChart();
        }
      });
    }

    const bubblesEl = document.getElementById("bubbles");
    function pushBubble() {
      const c = CONTRACTS[(Math.random() * CONTRACTS.length) | 0];
      const yes = Math.random() > 0.45;
      const amt = (Math.random() * 12000 + 200) | 0;
      const div = document.createElement("div");
      div.className = "bubble " + (yes ? "buy-yes" : "buy-no");
      div.innerHTML = `<span>${c.name} · ${yes ? "Yes" : "No"}</span><span class="amt">${fmtMoney(amt)}</span>`;
      bubblesEl.insertBefore(div, bubblesEl.firstChild);
      while (bubblesEl.children.length > 6) bubblesEl.removeChild(bubblesEl.lastChild);
    }

    let totalVolBase = 8018857;
    function tickVolume() {
      totalVolBase += (Math.random() * 800 + 100) | 0;
      document.getElementById("totalVol").textContent = fmtMoney(totalVolBase);
    }

    function tickOdds() {
      const top = getTopVolumeIndices(Math.min(4, CONTRACTS.length));
      const spine = (Math.random() - 0.5) * 0.024;
      const shock = Math.random() < 0.088 ? Math.sign(Math.random() - 0.5) * (0.038 + Math.random() * 0.04) : 0;
      CONTRACTS.forEach((c, si) => {
        const arr = oddsHistory[si];
        const last = arr[arr.length - 1];
        let delta = (Math.random() - 0.5) * 0.016;
        if (top[0] === si) delta += spine * 0.95 + shock * 0.42;
        if (top.length > 1 && top[1] === si) delta -= spine * 0.72 + shock * 0.38;
        if (top.includes(si) && Math.random() < 0.07) delta += (Math.random() - 0.5) * 0.048;
        const next = Math.max(0.01, Math.min(0.99, last + delta));
        arr.push(next);
        arr.shift();
        c.odds = next;
      });
      syncOddsToDom();
      updateCalc();
      resizeCanvas();
      drawEventChart(chartHover);
      if (openContractId && miniView === "chart") drawMiniChart();
    }

    function updateCalc() {
      const c = CONTRACTS.find((x) => x.id === selectedId);
      document.getElementById("selName").textContent = c ? c.name : "—";
      const amt = parseFloat(document.getElementById("calcAmount").value) || 0;
      const price = calcSide === "yes" ? c.odds : 1 - c.odds;
      const shares = price > 0 ? amt / price : 0;
      const payoutWin = shares * 1;
      const profitWin = payoutWin - amt;
      const mult = price > 0 ? (1 / price).toFixed(2) : "—";
      const heroProfit =
        amt > 0
          ? (profitWin >= 0 ? "+" : "−") + fmtMoney(Math.abs(profitWin))
          : "—";
      const heroClass =
        "calc-hero-profit" + (amt > 0 && profitWin < 0 ? " negative" : "");
      const payoutLabel = amt > 0 ? fmtMoney(payoutWin) : "—";
      const multLabel = amt > 0 ? mult + "x" : "—";
      document.getElementById("calcOut").innerHTML = `
        <div class="calc-hero">
          <div class="calc-hero-label">若判断正确 · 预估净收益</div>
          <div class="${heroClass}">${heroProfit}</div>
          <div class="calc-hero-sub">预计收回 <span>${payoutLabel}</span> · 约 <span>${multLabel}</span> 倍潜在空间</div>
        </div>
        <div class="calc-rows">
          <div class="row"><span class="k">方向</span><span class="v">${calcSide === "yes" ? "买入 Yes" : "买入 No"} @ ${(price * 100).toFixed(1)}¢</span></div>
          <div class="row row-highlight"><span class="k">约可买份额</span><span class="v">${amt > 0 ? shares.toFixed(2) + " 份" : "—"}</span></div>
          <div class="row"><span class="k">投入本金</span><span class="v">${amt > 0 ? fmtMoney(amt) : "—"}</span></div>
        </div>
      `;
    }

    document.getElementById("btnYes").addEventListener("click", () => {
      calcSide = "yes";
      document.getElementById("btnYes").classList.add("active-yes");
      document.getElementById("btnNo").classList.remove("active-no");
      updateCalc();
    });
    document.getElementById("btnNo").addEventListener("click", () => {
      calcSide = "no";
      document.getElementById("btnNo").classList.add("active-no");
      document.getElementById("btnYes").classList.remove("active-yes");
      updateCalc();
    });
    document.getElementById("calcAmount").addEventListener("input", updateCalc);
    document.getElementById("ctaTrade").addEventListener("click", () => {
      alert("Demo：此处跳转 App 深链 / 应用商店");
    });

    const SN_USERS = ["用户***8f", "Trader***21", "poly***ac", "desk***7e", "arbi***03", "wha***be"];

    function tickSnLine() {
      const u = SN_USERS[(Math.random() * SN_USERS.length) | 0];
      const contract = CONTRACTS.find((x) => x.id === selectedId) || CONTRACTS[0];
      const amt = (Math.random() * 18000 + 220) | 0;
      const userEl = document.getElementById("snUser");
      const contractEl = document.getElementById("snContract");
      const amtEl = document.getElementById("snAmt");
      if (!userEl || !contractEl || !amtEl) return;
      userEl.textContent = u;
      contractEl.textContent = contract.name;
      amtEl.textContent = fmtMoney(amt);
      amtEl.classList.remove("tick");
      void amtEl.offsetWidth;
      amtEl.classList.add("tick");
    }

    function fmtTime() {
      const d = new Date();
      return (
        String(d.getHours()).padStart(2, "0") +
        ":" +
        String(d.getMinutes()).padStart(2, "0") +
        ":" +
        String(d.getSeconds()).padStart(2, "0")
      );
    }

    function oneTradeRow(seed) {
      const buy = (Math.sin(seed * 0.7) * 10000 + Math.random() * 10000) % 1 > 0.42;
      const side = buy ? "yes" : "no";
      const c =
        CONTRACTS[(Math.floor(seed * 13) + Math.floor(Math.random() * 3)) % CONTRACTS.length];
      const k = (Math.random() * 8.2 + 0.35).toFixed(2);
      const cls = buy ? "buy" : "sell";
      return (
        `<div class="trade-row ${cls}">` +
        `<span class="trade-side ${side}">${buy ? "YES" : "NO"}</span>` +
        `<span class="trade-detail"><strong>${c.name}</strong> · 世界大赛</span>` +
        `<span class="trade-amt">$${k}K</span>` +
        `<span class="trade-time">${fmtTime()}</span>` +
        `</div>`
      );
    }

    function fillHotTrack(el, count, offset) {
      let html = "";
      for (let i = 0; i < count; i++) html += oneTradeRow(offset + i * 0.31);
      el.innerHTML = html + html;
    }

    function setupHotTrades() {
      const a = document.getElementById("hotTrackA");
      const b = document.getElementById("hotTrackB");
      const c = document.getElementById("hotTrackC");
      const layer = document.getElementById("hotToastLayer");
      if (!a || !b) return;
      fillHotTrack(a, 40, 0);
      fillHotTrack(b, 44, 77);
      if (c) fillHotTrack(c, 38, 150);
      function pushToast() {
        if (!layer) return;
        const buy = Math.random() > 0.35;
        const cn = CONTRACTS[(Math.random() * CONTRACTS.length) | 0];
        const k = (Math.random() * 9 + 0.18).toFixed(2);
        const mask = "***" + String(Math.floor(Math.random() * 900 + 100));
        const t = document.createElement("div");
        t.className = "hot-toast" + (buy ? "" : " sell-toast");
        t.innerHTML =
          (buy ? "🔥 火热" : "⚡ 平仓") +
          " · 用户 <strong>" +
          mask +
          "</strong> " +
          (buy ? "买入" : "卖出") +
          " <strong>" +
          cn.name +
          "</strong> " +
          (buy ? "YES" : "NO") +
          ' <span style="color:#fbbf24">$' +
          k +
          "K</span>";
        layer.appendChild(t);
        while (layer.children.length > 7) layer.removeChild(layer.firstChild);
        setTimeout(() => {
          if (t.parentNode === layer) layer.removeChild(t);
        }, 2800);
      }
      pushToast();
      setInterval(() => pushToast(), 900 + Math.random() * 700);
    }

    const RELATED = [
      { cat: "体育 · MLB", title: "2026 美联冠军", hot: true, topOdds: "洋基 18%", vol: "$6.2M" },
      { cat: "体育 · MLB", title: "2026 国联冠军", hot: false, topOdds: "道奇 24%", vol: "$4.8M" },
      { cat: "体育", title: "NBA 2026 总冠军", hot: true, topOdds: "雷霆 22%", vol: "$31M" },
      { cat: "金融", title: "标普 500 年终点位", hot: false, topOdds: ">6000 12%", vol: "$8.9M" },
      { cat: "政治", title: "某国大选出口民调", hot: true, topOdds: "候选人 A 51%", vol: "$22M" },
    ];
    document.getElementById("relatedEvents").innerHTML = RELATED.map(
      (r) => `
      <div class="ev-card ${r.hot ? "hot" : ""}">
        <div class="tag">${r.hot ? "🔥 交易火热" : r.cat}</div>
        <div class="en">${r.title}</div>
        <div class="odds-row">最大量合约：<span>${r.topOdds}</span></div>
        <div class="odds-row">事件总交易量：<span>${r.vol}</span></div>
      </div>`
    ).join("");

    let chartHover = null;
    eventCanvas.addEventListener("mousemove", (e) => {
      const rect = eventCanvas.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const padL = CHART_PAD.l;
      const padR = CHART_PAD.r;
      const cw = rect.width - padL - padR;
      let idx = Math.round(((x - padL) / cw) * (historyLen - 1));
      idx = Math.max(0, Math.min(historyLen - 1, idx));
      chartHover = idx;
      drawEventChart(chartHover);
    });
    eventCanvas.addEventListener("mouseleave", () => {
      chartHover = null;
      drawEventChart();
    });

    window.addEventListener("resize", () => {
      resizeCanvas();
      drawEventChart(chartHover);
      drawMiniChart();
    });

    setupHypeMarquee();
    setupCrowdPulse();
    renderLegend();
    renderContracts();
    setupMiniChartHover();
    renderHot24List();
    updateCalc();
    tickSnLine();
    resizeCanvas();
    drawEventChart();
    for (let i = 0; i < 5; i++) pushBubble();
    setupHotTrades();

    setInterval(tickOdds, 1000);
    setInterval(pushBubble, 1400);
    setInterval(tickVolume, 800);
    setInterval(() => {
      if (openContractId && miniView === "orderbook") renderOrderbook(openContractId);
    }, 900);
    setInterval(tickSnLine, 2800);
  </script>
</body>
</html>
