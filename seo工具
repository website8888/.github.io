    <script>
        let processedData = null;
        let finalReport = '';
        let uploadedFile = null;
        /** @type {null | { prev: object, curr: object, rawOcr: string }} */
        let gscScreenshotData = null;
        let screenshotObjectUrl = null;

        // —— GSC 截图 OCR ——
        function normalizeOcrText(t) {
            return String(t || '')
                .replace(/\r/g, '\n')
                .replace(/,/g, '.')
                .replace(/[Oo](?=\d)/g, '0');
        }

        function parseCompactNumber(s) {
            if (s == null || s === '') return NaN;
            const str = String(s).trim();
            const m = str.match(/^([\d.]+)\s*([KkMm])?/i);
            if (!m) return parseFloat(str.replace(/%/g, '')) || NaN;
            let n = parseFloat(m[1]);
            const u = (m[2] || '').toUpperCase();
            if (u === 'K') n *= 1e3;
            if (u === 'M') n *= 1e6;
            return n;
        }

        function formatTrendDisplay(currStr, prevStr) {
            const curr = parseCompactNumber(currStr);
            const prev = parseCompactNumber(prevStr);
            const cs = (currStr || '—').trim();
            if (!isFinite(curr) || !isFinite(prev)) return `${cs} (—)`;
            if (prev === 0) return `${cs} (+∞)`;
            const pct = ((curr - prev) / prev) * 100;
            const sign = pct > 0 ? '+' : '';
            return `${cs} (${sign}${pct.toFixed(1)}%)`;
        }

        function normalizeKToken(s) {
            return String(s).replace(/\s+/g, '').replace(/[KkXx]$/i, 'K');
        }

        /**
         * 提取 Total clicks 两期数值。OCR 常见问题：写成 Total click、K 被漏识别、40.8 与 49.1 无后缀。
         */
        function extractGscClicksPair(text, lower) {
            const clickM = lower.match(/total\s+clicks?/);
            const clickStart = clickM ? clickM.index : -1;
            const impM = lower.match(/total\s+impressions/);
            const impStart = impM ? impM.index : -1;
            const ctrM = lower.match(/average\s+ctr/);
            const ctrStart = ctrM ? ctrM.index : -1;

            const tryKInString = (str) => {
                const km = str.match(/\d+\.?\d*\s*[Kk]/g) || [];
                return km.slice(0, 2).map(normalizeKToken);
            };

            // 1) 截取「点击」列：从 Total click(s) 到下一个区块标题（支持 OCR 先印出 Impressions 再 Clicks）
            let segClick = '';
            if (clickStart >= 0) {
                const candidates = [impStart, ctrStart].filter((i) => i > clickStart);
                const end = candidates.length ? Math.min(...candidates) : text.length;
                segClick = text.slice(clickStart, end);
            }

            let pair = tryKInString(segClick);
            if (pair.length >= 2) return pair;

            // 2) Total click 与 Total impressions 之间的区间（无论谁先出现）
            if (clickStart >= 0 && impStart >= 0 && clickStart !== impStart) {
                const a = Math.min(clickStart, impStart);
                const b = Math.max(clickStart, impStart);
                pair = tryKInString(text.slice(a, b));
                if (pair.length >= 2) return pair;
            }

            // 3) 全文中的 K 数字（展示多为 M，点击多为 K，一般不与 3.xxM 混淆）
            pair = tryKInString(text);
            if (pair.length >= 2) return pair;

            // 4) 无 K 后缀：OCR 常识别成「40.8」「49.1」（略去 K）。排除 1.3% 类 CTR 与 3.xx（百万展示的误截断）
            const tryDecimalThousands = (str) => {
                const matches = str.match(/\b(\d{1,3}\.\d+)\b/g) || [];
                const nums = matches
                    .map((x) => parseFloat(x))
                    .filter((n) => {
                        if (n >= 2.4 && n <= 4.2) return false;
                        return n >= 1.5 && n <= 500;
                    });
                if (nums.length < 2) return [];
                return nums.slice(0, 2).map((n) => n.toFixed(1).replace(/\.0$/, '') + 'K');
            };

            if (segClick) {
                pair = tryDecimalThousands(segClick);
                if (pair.length >= 2) return pair;
            }
            if (clickStart >= 0 && impStart >= 0) {
                const a = Math.min(clickStart, impStart);
                const b = Math.max(clickStart, impStart);
                pair = tryDecimalThousands(text.slice(a, b));
                if (pair.length >= 2) return pair;
            }

            // 4b) 行优先 OCR：「Total impressions」之前的正文往往是点击列（含 40.8 / 49.1）
            if (impStart > 0) {
                pair = tryDecimalThousands(text.slice(0, impStart));
                if (pair.length >= 2) return pair;
            }

            // 5) 纯数字 4～6 位（40800、49100）
            const tryIntThousands = (str) => {
                const raw = str.match(/\b([4-9]\d{4}|[1-9]\d{5})\b/g) || [];
                if (raw.length < 2) return [];
                return raw.slice(0, 2).map((n) => {
                    const v = parseInt(n, 10);
                    if (v >= 1000) return (v / 1000).toFixed(1).replace(/\.0$/, '') + 'K';
                    return n + 'K';
                });
            };
            pair = tryIntThousands(segClick || '');
            if (pair.length >= 2) return pair;

            return [];
        }

        /**
         * 从 OCR 文本解析 GSC 三卡片：Total clicks (K)、Total impressions (M/K)、Average CTR (%)
         * 约定：每列自上而下为先旧周期、后新周期（与截图一致）
         */
        function parseGscOcrText(raw, columnTexts) {
            const text = normalizeOcrText(raw);
            const lower = text.toLowerCase();

            const clickM = lower.match(/total\s+clicks?/);
            const clickStart = clickM ? clickM.index : -1;
            const impM = lower.match(/total\s+impressions/);
            const impStart = impM ? impM.index : -1;
            const ctrM = lower.match(/average\s+ctr/);
            const ctrStart = ctrM ? ctrM.index : -1;

            let clicksPair = [];
            if (columnTexts && columnTexts[0]) {
                clicksPair = extractClicksFromLeftColumnText(columnTexts[0]);
            }
            if (clicksPair.length < 2) {
                clicksPair = extractGscClicksPair(text, lower);
            }

            let impPair = [];
            if (impStart >= 0 && ctrStart > impStart) {
                const seg = text.slice(impStart, ctrStart);
                let mm = seg.match(/\d+\.?\d*\s*[Mm]/g) || [];
                if (mm.length < 2) mm = seg.match(/\d+\.?\d*\s*[Kk]/g) || [];
                impPair = mm.slice(0, 2).map(s => {
                    const t = s.replace(/\s+/g, '');
                    if (/m/i.test(t)) return t.replace(/m/i, 'M');
                    return t.replace(/k/i, 'K');
                });
            }
            if (impPair.length < 2) {
                const all = text.match(/\d+\.?\d*\s*[Mm]/g) || [];
                impPair = all.slice(0, 2).map(s => s.replace(/\s+/g, '').replace(/m/i, 'M'));
            }

            let ctrPair = [];
            if (ctrStart >= 0) {
                const seg = text.slice(ctrStart);
                const pct = seg.match(/\d+\.?\d*\s*%/g) || [];
                ctrPair = pct.slice(0, 2).map(s => s.trim().replace(/\s+/g, ''));
            }
            if (ctrPair.length < 2) {
                const all = text.match(/\d+\.?\d*\s*%/g) || [];
                ctrPair = all.slice(0, 2).map(s => s.trim().replace(/\s+/g, ''));
            }

            const dateRe = /\d{1,2}\/\d{1,2}\/\d{2}\s*-\s*\d{1,2}\/\d{1,2}\/\d{2}/g;
            const dates = [];
            let m;
            while ((m = dateRe.exec(text)) !== null) dates.push(m[0]);

            let prevDateRange = '';
            let currDateRange = '';
            if (dates.length >= 2) {
                prevDateRange = dates[0];
                currDateRange = dates[1];
            }

            const prev = {
                impressions: impPair[0] || '',
                clicks: clicksPair[0] || '',
                ctr: ctrPair[0] || '',
                dateRange: prevDateRange
            };
            const curr = {
                impressions: impPair[1] || '',
                clicks: clicksPair[1] || '',
                ctr: ctrPair[1] || '',
                dateRange: currDateRange
            };

            const ok =
                (prev.clicks && curr.clicks) ||
                (prev.impressions && curr.impressions) ||
                (prev.ctr && curr.ctr);

            return { prev, curr, rawOcr: raw, parseOk: !!ok };
        }

        function applyGscExtractToUI(parsed) {
            const panel = document.getElementById('gscExtractPanel');
            const { prev, curr } = parsed;
            document.getElementById('gscPrevImp').textContent = prev.impressions || '—';
            document.getElementById('gscPrevClk').textContent = prev.clicks || '—';
            document.getElementById('gscPrevCtr').textContent = prev.ctr || '—';
            document.getElementById('gscCurrImp').textContent = curr.impressions || '—';
            document.getElementById('gscCurrClk').textContent = curr.clicks || '—';
            document.getElementById('gscCurrCtr').textContent = curr.ctr || '—';
            document.getElementById('gscRowPrevLabel').textContent = prev.dateRange ? `上一周期 (${prev.dateRange})` : '上一周期';
            document.getElementById('gscRowCurrLabel').textContent = curr.dateRange ? `本周期 (${curr.dateRange})` : '本周期';
            panel.classList.add('active');
        }

        function imageToCanvasForOcr(img) {
            const maxW = 2000;
            let w = img.naturalWidth || img.width;
            let h = img.naturalHeight || img.height;
            if (w > maxW) {
                h = Math.round((h * maxW) / w);
                w = maxW;
            }
            const canvas = document.createElement('canvas');
            canvas.width = w;
            canvas.height = h;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0, w, h);
            return canvas;
        }

        /** 裁掉上方约 topCutRatio，保留下方（适合整页截图里 GSC 三卡片在偏下位置） */
        function cropBottomFraction(sourceCanvas, topCutRatio) {
            const w = sourceCanvas.width;
            const h = sourceCanvas.height;
            const top = Math.floor(h * topCutRatio);
            const nh = h - top;
            if (nh < 80) return sourceCanvas;
            const out = document.createElement('canvas');
            out.width = w;
            out.height = nh;
            out.getContext('2d').drawImage(sourceCanvas, 0, top, w, nh, 0, 0, w, nh);
            return out;
        }

        /** 裁出左/中/右三列（与 GSC 三卡片同序：Clicks | Impressions | CTR） */
        function cropColumnCanvas(sourceCanvas, colIndex, cols) {
            const w = sourceCanvas.width;
            const h = sourceCanvas.height;
            const cw = Math.floor(w / cols);
            const x = colIndex * cw;
            const out = document.createElement('canvas');
            out.width = cw;
            out.height = h;
            const ctx = out.getContext('2d');
            ctx.drawImage(sourceCanvas, x, 0, cw, h, 0, 0, cw, h);
            return out;
        }

        /** 窄列放大后再 OCR，减轻小字漏识别 */
        function maybeUpscaleCanvas(canvas, minWidth) {
            if (canvas.width >= minWidth) return canvas;
            const scale = Math.min(3, minWidth / canvas.width);
            const out = document.createElement('canvas');
            out.width = Math.round(canvas.width * scale);
            out.height = Math.round(canvas.height * scale);
            const ctx = out.getContext('2d');
            ctx.imageSmoothingEnabled = true;
            ctx.imageSmoothingQuality = 'high';
            ctx.drawImage(canvas, 0, 0, out.width, out.height);
            return out;
        }

        /**
         * 仅从「左列」OCR 文本提取点击两期（不依赖全文里 Total clicks 出现顺序）
         */
        function extractClicksFromLeftColumnText(colText) {
            if (!colText || !String(colText).trim()) return [];
            const t = normalizeOcrText(colText);
            const tryK = (s) => {
                const km = s.match(/\d+\.?\d*\s*[KkXx]/g) || [];
                return km.slice(0, 2).map((x) => normalizeKToken(x));
            };
            let pair = tryK(t);
            if (pair.length >= 2) return pair;

            const tryDecimalThousands = (str) => {
                const matches = str.match(/\b(\d{1,3}\.\d+)\b/g) || [];
                const nums = matches
                    .map((x) => parseFloat(x))
                    .filter((n) => {
                        if (n >= 2.4 && n <= 4.2) return false;
                        return n >= 1.5 && n <= 500;
                    });
                if (nums.length < 2) return [];
                return nums.slice(0, 2).map((n) => n.toFixed(1).replace(/\.0$/, '') + 'K');
            };
            pair = tryDecimalThousands(t);
            if (pair.length >= 2) return pair;

            const raw = t.match(/\b([4-9]\d{4}|[1-9]\d{5})\b/g) || [];
            if (raw.length >= 2) {
                return raw.slice(0, 2).map((n) => {
                    const v = parseInt(n, 10);
                    return v >= 1000 ? (v / 1000).toFixed(1).replace(/\.0$/, '') + 'K' : n + 'K';
                });
            }
            return [];
        }

        /**
         * 返回整图 OCR + 三列分别 OCR（解决整图阅读顺序导致漏掉蓝色 Total clicks 列）
         */
        async function runOcrOnImageSource(src) {
            const el = new Image();
            await new Promise((resolve, reject) => {
                el.onload = resolve;
                el.onerror = () => reject(new Error('图片加载失败'));
                el.src = src;
            });
            const canvas = imageToCanvasForOcr(el);
            const statusEl = document.getElementById('ocrStatus');
            statusEl.textContent = '正在识别文字（首次加载可能需要下载模型）…';
            statusEl.classList.remove('error');

            if (typeof Tesseract === 'undefined') {
                throw new Error('OCR 库未加载，请检查网络后刷新页面');
            }

            const worker = await Tesseract.createWorker('eng');
            try {
                const { data: { text: fullText } } = await worker.recognize(canvas);

                await worker.setParameters({
                    tessedit_pageseg_mode: '6'
                });

                const ocrOneCol = async (baseCanvas, c) => {
                    let colCanvas = cropColumnCanvas(baseCanvas, c, 3);
                    colCanvas = maybeUpscaleCanvas(colCanvas, 420);
                    const { data: { text } } = await worker.recognize(colCanvas);
                    return text || '';
                };

                const columns = [];
                for (let c = 0; c < 3; c++) {
                    statusEl.textContent = `正在识别第 ${c + 1}/3 列（对齐 GSC 三卡片）…`;
                    columns.push(await ocrOneCol(canvas, c));
                }

                if (extractClicksFromLeftColumnText(columns[0]).length < 2) {
                    statusEl.textContent = '正在对下方区域单独识别点击列（排除页顶工具栏干扰）…';
                    for (const ratio of [0.22, 0.38, 0.52]) {
                        const sub = cropBottomFraction(canvas, ratio);
                        if (sub === canvas) continue;
                        const alt = await ocrOneCol(sub, 0);
                        if (extractClicksFromLeftColumnText(alt).length >= 2) {
                            columns[0] = alt;
                            break;
                        }
                    }
                }

                return { fullText, columns };
            } finally {
                await worker.terminate();
            }
        }

        async function handleScreenshotFile(file) {
            if (!file || !file.type.startsWith('image/')) {
                document.getElementById('ocrStatus').textContent = '请选择图片文件';
                document.getElementById('ocrStatus').classList.add('error');
                return;
            }
            if (screenshotObjectUrl) {
                URL.revokeObjectURL(screenshotObjectUrl);
                screenshotObjectUrl = null;
            }
            screenshotObjectUrl = URL.createObjectURL(file);
            document.getElementById('screenshotPreview').src = screenshotObjectUrl;
            document.getElementById('screenshotPreviewWrap').classList.add('active');
            document.getElementById('clearScreenshotBtn').style.display = 'inline-block';

            try {
                const ocr = await runOcrOnImageSource(screenshotObjectUrl);
                const parsed = parseGscOcrText(ocr.fullText, ocr.columns);
                const rawOcr = ocr.fullText
                    + '\n\n--- 左列(Clicks) ---\n' + (ocr.columns[0] || '')
                    + '\n--- 中列(Impressions) ---\n' + (ocr.columns[1] || '')
                    + '\n--- 右列(CTR) ---\n' + (ocr.columns[2] || '');
                gscScreenshotData = { prev: parsed.prev, curr: parsed.curr, rawOcr, columnOcr: ocr.columns };
                applyGscExtractToUI(parsed);
                if (parsed.parseOk) {
                    document.getElementById('ocrStatus').textContent = '已解析截图中的整体表现数据 ✓';
                    document.getElementById('ocrStatus').classList.remove('error');
                } else {
                    document.getElementById('ocrStatus').textContent = '未能可靠识别数值，请换更清晰的截图或稍后重试；周报「整体表现」将使用关键词表汇总。';
                    document.getElementById('ocrStatus').classList.add('error');
                }
            } catch (e) {
                console.error(e);
                gscScreenshotData = null;
                document.getElementById('ocrStatus').textContent = '识别失败：' + e.message;
                document.getElementById('ocrStatus').classList.add('error');
            }
        }

        function clearScreenshot() {
            if (screenshotObjectUrl) {
                URL.revokeObjectURL(screenshotObjectUrl);
                screenshotObjectUrl = null;
            }
            gscScreenshotData = null;
            document.getElementById('screenshotPreview').removeAttribute('src');
            document.getElementById('screenshotPreviewWrap').classList.remove('active');
            document.getElementById('clearScreenshotBtn').style.display = 'none';
            document.getElementById('ocrStatus').textContent = '';
            document.getElementById('ocrStatus').classList.remove('error');
            document.getElementById('gscExtractPanel').classList.remove('active');
            document.getElementById('screenshotInput').value = '';
        }

        const screenshotSection = document.getElementById('screenshotSection');
        document.getElementById('pickScreenshotBtn').addEventListener('click', () => {
            document.getElementById('screenshotInput').click();
        });
        document.getElementById('screenshotInput').addEventListener('change', (e) => {
            if (e.target.files && e.target.files[0]) handleScreenshotFile(e.target.files[0]);
        });
        document.getElementById('clearScreenshotBtn').addEventListener('click', clearScreenshot);

        screenshotSection.addEventListener('paste', (e) => {
            const items = e.clipboardData && e.clipboardData.items;
            if (!items) return;
            for (let i = 0; i < items.length; i++) {
                if (items[i].type.indexOf('image') !== -1) {
                    e.preventDefault();
                    const file = items[i].getAsFile();
                    if (file) handleScreenshotFile(file);
                    break;
                }
            }
        });

        screenshotSection.addEventListener('dragover', (e) => {
            e.preventDefault();
            screenshotSection.classList.add('paste-focus');
        });
        screenshotSection.addEventListener('dragleave', () => {
            screenshotSection.classList.remove('paste-focus');
        });
        screenshotSection.addEventListener('drop', (e) => {
            e.preventDefault();
            screenshotSection.classList.remove('paste-focus');
            const f = e.dataTransfer.files && e.dataTransfer.files[0];
            if (f && f.type.startsWith('image/')) handleScreenshotFile(f);
        });

        // 拖拽上传
        const uploadSection = document.getElementById('uploadSection');
        const fileInput = document.getElementById('fileInput');

        uploadSection.addEventListener('dragover', (e) => {
            e.preventDefault();
            uploadSection.classList.add('dragover');
        });

        uploadSection.addEventListener('dragleave', () => {
            uploadSection.classList.remove('dragover');
        });

        uploadSection.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadSection.classList.remove('dragover');
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                handleFile(files[0]);
            }
        });

        uploadSection.addEventListener('click', (e) => {
            if (e.target.tagName !== 'BUTTON') {
                fileInput.click();
            }
        });

        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                handleFile(e.target.files[0]);
            }
        });

        function handleFile(file) {
            uploadedFile = file;
            const fileInfo = document.getElementById('fileInfo');
            document.getElementById('fileName').textContent = file.name;
            document.getElementById('fileSize').textContent = formatFileSize(file.size);
            fileInfo.classList.add('active');
            document.getElementById('processBtn').disabled = false;

            // 预览行数
            const reader = new FileReader();
            reader.onload = (e) => {
                try {
                    let rowCount = 0;
                    if (file.name.endsWith('.csv')) {
                        const text = e.target.result;
                        rowCount = text.split('\n').length - 1;
                    } else {
                        const data = new Uint8Array(e.target.result);
                        const workbook = XLSX.read(data, { type: 'array' });
                        const sheet = workbook.Sheets[workbook.SheetNames[0]];
                        const jsonData = XLSX.utils.sheet_to_json(sheet);
                        rowCount = jsonData.length;
                    }
                    document.getElementById('rowCount').textContent = rowCount;
                } catch (err) {
                    console.error('Error reading file:', err);
                }
            };

            if (file.name.endsWith('.csv')) {
                reader.readAsText(file);
            } else {
                reader.readAsArrayBuffer(file);
            }
        }

        function formatFileSize(bytes) {
            if (bytes < 1024) return bytes + ' B';
            if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(2) + ' KB';
            return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
        }

        async function startProcessing() {
            if (!uploadedFile) return;

            document.getElementById('processBtn').disabled = true;
            document.getElementById('progressSection').classList.add('active');
            document.getElementById('errorMessage').innerHTML = '';

            try {
                // Step 1: 读取文件
                await updateProgress(1, 'processing', 20, '正在读取文件...');
                const csvContent = await readFileAsCSV(uploadedFile);

                await sleep(300);
                await updateProgress(1, 'processing', 50, '正在解析数据...');

                // Step 1: 数据分析（整体表现优先使用 GSC 截图识别结果）
                processedData = processData(csvContent, gscScreenshotData);
                await sleep(300);
                await updateProgress(1, 'completed', 100, '数据分析完成 ✓');

                await sleep(500);

                // Step 2: 生成报告
                await updateProgress(2, 'processing', 30, '正在生成报告结构...');
                await sleep(500);

                await updateProgress(2, 'processing', 60, '正在分析数据洞察...');
                finalReport = generateReport(processedData);
                await sleep(500);

                await updateProgress(2, 'processing', 90, '正在格式化报告...');
                await sleep(300);

                await updateProgress(2, 'completed', 100, '报告生成完成 ✓');

                // 显示结果
                await sleep(500);
                displayResults();

            } catch (error) {
                showError('处理出错：' + error.message);
                console.error(error);
                document.getElementById('processBtn').disabled = false;
            }
        }

        async function readFileAsCSV(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();

                reader.onload = (e) => {
                    try {
                        let csvContent = '';

                        if (file.name.endsWith('.csv')) {
                            csvContent = e.target.result;
                        } else {
                            // Excel file
                            const data = new Uint8Array(e.target.result);
                            const workbook = XLSX.read(data, { type: 'array' });
                            const firstSheet = workbook.Sheets[workbook.SheetNames[0]];
                            csvContent = XLSX.utils.sheet_to_csv(firstSheet);
                        }

                        resolve(csvContent);
                    } catch (err) {
                        reject(err);
                    }
                };

                reader.onerror = () => reject(new Error('文件读取失败'));

                if (file.name.endsWith('.csv')) {
                    reader.readAsText(file);
                } else {
                    reader.readAsArrayBuffer(file);
                }
            });
        }

        function buildSummaryFromGscScreenshot(g) {
            if (!g || !g.prev || !g.curr) return null;
            const p = g.prev;
            const c = g.curr;
            const hasImp = p.impressions && c.impressions;
            const hasClk = p.clicks && c.clicks;
            const hasCtr = p.ctr && c.ctr;
            if (!hasImp && !hasClk && !hasCtr) return null;

            let period = '最近一周 vs 上一周期';
            if (p.dateRange && c.dateRange) {
                period = `${p.dateRange} → ${c.dateRange}`;
            } else if (p.dateRange || c.dateRange) {
                period = [p.dateRange, c.dateRange].filter(Boolean).join(' → ');
            }

            return {
                period,
                total_imp: hasImp ? formatTrendDisplay(c.impressions, p.impressions) : null,
                total_clk: hasClk ? formatTrendDisplay(c.clicks, p.clicks) : null,
                avg_ctr_curr: hasCtr ? c.ctr : null,
                avg_ctr_prev: hasCtr ? p.ctr : null
            };
        }

        function mergeSummaryStats(csvStats, gscExtract) {
            const fromShot = buildSummaryFromGscScreenshot(gscExtract);
            if (!fromShot) {
                return {
                    ...csvStats,
                    _source: 'csv_aggregate'
                };
            }
            return {
                period: fromShot.period || csvStats.period,
                total_imp: fromShot.total_imp != null ? fromShot.total_imp : csvStats.total_imp,
                total_clk: fromShot.total_clk != null ? fromShot.total_clk : csvStats.total_clk,
                avg_ctr_curr: fromShot.avg_ctr_curr != null ? fromShot.avg_ctr_curr : csvStats.avg_ctr_curr,
                avg_ctr_prev: fromShot.avg_ctr_prev != null ? fromShot.avg_ctr_prev : csvStats.avg_ctr_prev,
                _source: 'gsc_screenshot'
            };
        }

        function processData(csvContent, gscExtract) {
            const lines = csvContent.trim().split('\n');
            const header = lines[0].split(',');

            let totalClkCurr = 0, totalClkPrev = 0;
            let totalImpCurr = 0, totalImpPrev = 0;
            const keywordsData = [];

            for (let i = 1; i < lines.length; i++) {
                const values = parseCSVLine(lines[i]);
                if (values.length < 5) continue;

                const query = values[0].trim();
                const clkPrev = parseFloat(values[1].replace(/,/g, '')) || 0;
                const clkCurr = parseFloat(values[2].replace(/,/g, '')) || 0;
                const impPrev = parseFloat(values[3].replace(/,/g, '')) || 0;
                const impCurr = parseFloat(values[4].replace(/,/g, '')) || 0;
                const diff = clkCurr - clkPrev;

                totalClkCurr += clkCurr;
                totalClkPrev += clkPrev;
                totalImpCurr += impCurr;
                totalImpPrev += impPrev;

                keywordsData.push({
                    query, diff, clkCurr, clkPrev, impCurr, impPrev
                });
            }

            // 分类品牌词和非品牌词
            const brandTerms = ['moomoo', 'futu', 'ムームー', '富途'];
            const brandData = [];
            const nonBrandData = [];

            keywordsData.forEach(item => {
                const isBrand = brandTerms.some(term =>
                    item.query.toLowerCase().includes(term.toLowerCase())
                );

                const sign = item.diff > 0 ? '+' : '';
                const display = `${item.query} | ${sign}${Math.round(item.diff)}`;

                const dataObj = { ...item, display };

                if (isBrand) {
                    brandData.push(dataObj);
                } else {
                    nonBrandData.push(dataObj);
                }
            });

            brandData.sort((a, b) => b.diff - a.diff);
            nonBrandData.sort((a, b) => b.diff - a.diff);

            const formatTrend = (curr, prev) => {
                if (prev === 0) return `${Math.round(curr)} (+∞)`;
                const pct = ((curr - prev) / prev) * 100;
                const sign = pct > 0 ? '+' : '';
                return `${Math.round(curr)} (${sign}${pct.toFixed(1)}%)`;
            };

            const calculateCTR = (clicks, impressions) => {
                if (impressions === 0) return '0.00%';
                return `${((clicks / impressions) * 100).toFixed(2)}%`;
            };

            const csvSummary = {
                period: "最近一周 vs 上一周期",
                total_imp: formatTrend(totalImpCurr, totalImpPrev),
                total_clk: formatTrend(totalClkCurr, totalClkPrev),
                avg_ctr_curr: calculateCTR(totalClkCurr, totalImpCurr),
                avg_ctr_prev: calculateCTR(totalClkPrev, totalImpPrev)
            };

            const summary_stats = mergeSummaryStats(csvSummary, gscExtract);

            const out = {
                summary_stats,
                non_brand_analysis: {
                    risers: nonBrandData.filter(x => x.diff > 0).slice(0, 10).map(x => x.display),
                    fallers: nonBrandData.filter(x => x.diff < 0).reverse().slice(0, 10).map(x => x.display)
                },
                brand_analysis: {
                    risers: brandData.filter(x => x.diff > 0).slice(0, 5).map(x => x.display),
                    fallers: brandData.filter(x => x.diff < 0).reverse().slice(0, 5).map(x => x.display)
                },
                raw_data: keywordsData
            };

            if (gscExtract && (gscExtract.prev || gscExtract.curr)) {
                out.gsc_screenshot = {
                    prev: gscExtract.prev,
                    curr: gscExtract.curr,
                    rawOcr: gscExtract.rawOcr ? String(gscExtract.rawOcr).slice(0, 8000) : ''
                };
            }

            return out;
        }

        function parseCSVLine(line) {
            const result = [];
            let current = '';
            let inQuotes = false;

            for (let i = 0; i < line.length; i++) {
                const char = line[i];

                if (char === '"') {
                    inQuotes = !inQuotes;
                } else if (char === ',' && !inQuotes) {
                    result.push(current);
                    current = '';
                } else {
                    current += char;
                }
            }
            result.push(current);

            return result;
        }

